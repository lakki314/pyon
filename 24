---
- name: Initialize per-host tracking
  set_fact:
    jvm_results: "{{ jvm_results | default([]) }}"
    owners_touched: "{{ owners_touched | default([]) }}"
    cached_install_root: "{{ cached_install_root | default('') }}"
    cached_install_owner: "{{ cached_install_owner | default('') }}"
    discovered_jvms: []
    profile_batches: {}
    source_map: {}
  changed_when: false

- name: Setup remote tmp for AIX-friendly operations
  include_tasks: setup_remote_tmp.yml

- name: Validate host_jvms exist
  assert:
    that:
      - host_jvms is defined
      - host_jvms | length > 0
    fail_msg: "No host_jvms supplied on {{ inventory_hostname }}."

# ---- Discover profile/owner per JVM ----
- name: Discover each JVM (profile + owner)
  include_tasks: discover_jvm.yml
  loop: "{{ host_jvms | map('trim') | unique | list }}"
  loop_control:
    loop_var: jvm_name
    label: "{{ inventory_hostname }} -> discover {{ jvm_name }}"

- name: Debug - discovered JVMs with sources (per host)
  when: wsjvm_debug | bool
  debug:
    msg:
      jvm: "{{ item.jvm_name }}"
      source: "{{ item.discovery_source }}"
      owner: "{{ item.jvm_owner }}"
      profile: "{{ item.profile_name }}"
      profile_dir: "{{ item.profile_dir }}"
  loop: "{{ discovered_jvms }}"
  loop_control:
    label: "{{ item.jvm_name }}"

# Build a quick lookup map for record_one_jvm.yml
- name: Build source_map (jvm_name -> discovery_source)
  set_fact:
    source_map: "{{ source_map | combine({ (item.jvm_name | trim): (item.discovery_source | default('unknown')) }) }}"
  loop: "{{ discovered_jvms }}"
  loop_control:
    label: "{{ item.jvm_name }}"
  changed_when: false

# ---- Build profile_batches keyed by profile_bin + owner ----
- name: Build profile batches (profile_bin+owner -> jvms)
  set_fact:
    profile_batches: >-
      {{
        profile_batches
        | combine(
            {
              (item.profile_bin ~ '||' ~ item.jvm_owner): {
                'profile_bin': item.profile_bin,
                'profile_dir': item.profile_dir,
                'profile_name': item.profile_name,
                'jvm_owner': item.jvm_owner,
                'jvms': ( (profile_batches.get(item.profile_bin ~ '||' ~ item.jvm_owner, {}).get('jvms', [])) + [ item.jvm_name ] )
              }
            },
            recursive=True
          )
      }}
  loop: "{{ discovered_jvms }}"
  loop_control:
    label: "{{ item.jvm_name }} -> {{ item.profile_name }}"

- name: Convert profile_batches to list
  set_fact:
    profile_batch_list: "{{ profile_batches | dict2items | map(attribute='value') | list }}"

# ---- Add batch_sources + summary for debug/passing ----
- name: Enrich profile batches with batch_sources (ps_words/filesystem_cache)
  set_fact:
    profile_batch_list: >-
      {{
        profile_batch_list
        | map('combine', {
            'batch_sources': (
              discovered_jvms
              | selectattr('profile_bin', 'equalto', item.profile_bin)
              | selectattr('jvm_owner', 'equalto', item.jvm_owner)
              | map(attribute='discovery_source')
              | list
              | unique
            )
          })
        | list
      }}
  vars:
    item: "{{ item0 }}"
  loop: "{{ profile_batch_list }}"
  loop_control:
    loop_var: item0
  changed_when: false

- name: Debug - profile batch sources
  when: wsjvm_debug | bool
  debug:
    msg:
      profile: "{{ item.profile_name }}"
      profile_dir: "{{ item.profile_dir }}"
      owner: "{{ item.jvm_owner }}"
      jvms: "{{ item.jvms }}"
      batch_sources: "{{ item.batch_sources | default([]) }}"
  loop: "{{ profile_batch_list }}"
  loop_control:
    label: "{{ item.profile_name }}"

# ---- Process each profile batch ----
- name: Restart JVMs per profile batch
  include_tasks: restart_profile.yml
  loop: "{{ profile_batch_list }}"
  loop_control:
    loop_var: profile_batch
    label: "{{ inventory_hostname }} -> {{ profile_batch.profile_name }} -> {{ profile_batch.jvms | join(',') }}"
  vars:
    profile_dir: "{{ profile_batch.profile_dir }}"
    profile_bin: "{{ profile_batch.profile_bin }}"
    jvm_owner: "{{ profile_batch.jvm_owner }}"
    profile_jvms: "{{ profile_batch.jvms | map('trim') | unique | list }}"
    profile_name_for_ps: "{{ profile_batch.profile_name }}"
    batch_sources: "{{ profile_batch.batch_sources | default([]) }}"
    batch_source_summary: "{{ (profile_batch.batch_sources | default([])) | unique | join(',') }}"
    source_map: "{{ source_map }}"
  always:
    - name: Cleanup banners (always)
      include_tasks: banner_cleanup.yml
      when: (restart_banner_enabled | default(true)) | bool

Note: The Enrich profile batches with batch_sources block uses map('combine', ...) with per-item context; if your controller flags it, I can rewrite it as a simple loop that builds a new list. But on AAP 2.6, this should work fine.

