---
- name: Normalize result JVM
  set_fact:
    result_jvm_norm: "{{ result_jvm | trim }}"
  changed_when: false

# PS after
- name: PS after for DMGR
  shell: "ps -ef | grep dmgr | grep {{ (profile_dir | basename) | quote }} | grep -v grep"
  register: _ps_after
  changed_when: false
  failed_when: false
  when: result_jvm_norm == 'dmgr'

- name: PS after for NODEAGENT
  shell: "ps -ef | grep nodeagent | grep {{ (profile_dir | basename) | quote }} | grep -v grep"
  register: _ps_after
  changed_when: false
  failed_when: false
  when: result_jvm_norm == 'nodeagent'

- name: PS after for AppServer
  shell: "ps -ef | grep java | grep {{ result_jvm_norm | quote }} | grep -v grep"
  register: _ps_after
  changed_when: false
  failed_when: false
  when: result_jvm_norm not in ['dmgr','nodeagent']

- name: Normalize serverStatus post lines
  set_fact:
    _post_lines_norm: >-
      {{
        (server_status_post.stdout_lines | default([]))
        | map('regex_replace', '\r', '')
        | map('regex_replace', '[ \t]+', ' ')
        | map('trim')
        | list
      }}
  changed_when: false

- name: Init expected started line
  set_fact:
    _expected_started_line: ""
  changed_when: false

- name: Expected STARTED line for NODEAGENT
  set_fact:
    _expected_started_line: 'ADMU0508I: The Node Agent "nodeagent" is STARTED'
  changed_when: false
  when: result_jvm_norm == 'nodeagent'

- name: Expected STARTED line for DMGR
  set_fact:
    _expected_started_line: 'ADMU0508I: The Deployment Manager "dmgr" is STARTED'
  changed_when: false
  when: result_jvm_norm == 'dmgr'

- name: Expected STARTED line for Application Server
  set_fact:
    _expected_started_line: "ADMU0508I: The Application Server \"{{ result_jvm_norm }}\" is STARTED"
  changed_when: false
  when: result_jvm_norm not in ['dmgr','nodeagent']

- name: Extract pid/cell and started_ok
  set_fact:
    ps_after_lines: "{{ _ps_after.stdout_lines | default([]) }}"
    new_pid: "{{ (ps_after_lines | length > 0) | ternary((ps_after_lines[0].split()[1]), 'not found via ps') }}"
    cell_name: "{{ (ps_after_lines | length > 0) | ternary((ps_after_lines[0].split()[-3]), 'unknown') }}"
    started_ok: "{{ (_expected_started_line | length > 0) and (_expected_started_line in _post_lines_norm) }}"
  changed_when: false

- name: Append per-JVM result (includes discovery_source)
  set_fact:
    jvm_results: >-
      {{
        jvm_results + [
          {
            'env_name': (env_name | default('na')),
            'env_host_profile_jvm': ((env_name | default('na')) ~ ':' ~ inventory_hostname ~ ':' ~ (profile_dir | basename) ~ ':' ~ result_jvm_norm),
            'status': ( 'success' if started_ok else 'failed' ),
            'profile_dir': profile_dir,
            'cell_name': cell_name,
            'new_pid': new_pid,
            'discovery_source': (source_map.get(result_jvm_norm, 'unknown') if source_map is defined else 'unknown'),
            'action': ( 'restart' if (result_jvm_norm in (jvms_started_pre | default([]))) else 'start' ),
            'reason': ( '' if started_ok else ('Not STARTED after operations (missing: ' ~ _expected_started_line ~ ')') )
          }
        ]
      }}
