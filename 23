roles/websphere_jvm_restart/tasks/execute_on_host.yml
---
- name: Initialize per-host tracking
  set_fact:
    jvm_results: "{{ jvm_results | default([]) }}"
    owners_touched: "{{ owners_touched | default([]) }}"
    cached_install_root: "{{ cached_install_root | default('') }}"
    cached_install_owner: "{{ cached_install_owner | default('') }}"
    discovered_jvms: []
    profile_batches: {}
  changed_when: false

- name: Setup remote tmp for AIX-friendly operations
  include_tasks: setup_remote_tmp.yml

- name: Validate host_jvms exist
  assert:
    that:
      - host_jvms is defined
      - host_jvms | length > 0
    fail_msg: "No host_jvms supplied on {{ inventory_hostname }}."

- name: Debug - host input
  when: wsjvm_debug | bool
  debug:
    msg:
      host: "{{ inventory_hostname }}"
      env: "{{ env_name }}"
      ritm: "{{ ritm_number }}"
      host_jvms: "{{ host_jvms }}"

# ---- Discover profile/owner per JVM ----
- name: Discover each JVM (profile + owner)
  include_tasks: discover_jvm.yml
  loop: "{{ host_jvms | map('trim') | unique | list }}"
  loop_control:
    loop_var: jvm_name
    label: "{{ inventory_hostname }} -> discover {{ jvm_name }}"

# ---- Build profile_batches keyed by profile_bin + owner ----
- name: Build profile batches (profile_bin+owner -> jvms)
  set_fact:
    profile_batches: >-
      {{
        profile_batches
        | combine(
            {
              (item.profile_bin ~ '||' ~ item.jvm_owner): {
                'profile_bin': item.profile_bin,
                'profile_dir': item.profile_dir,
                'jvm_owner': item.jvm_owner,
                'jvms': ( (profile_batches.get(item.profile_bin ~ '||' ~ item.jvm_owner, {}).get('jvms', [])) + [ item.jvm_name ] )
              }
            },
            recursive=True
          )
      }}
  loop: "{{ discovered_jvms }}"
  loop_control:
    label: "{{ item.jvm_name }} -> {{ item.profile_bin }}"

- name: Convert profile_batches to list
  set_fact:
    profile_batch_list: "{{ profile_batches | dict2items | map(attribute='value') | list }}"

- name: Debug - profile batches
  when: wsjvm_debug | bool
  debug:
    var: profile_batch_list

# ---- Process each profile batch ----
- name: Restart JVMs per profile batch
  include_tasks: restart_profile.yml
  loop: "{{ profile_batch_list }}"
  loop_control:
    loop_var: profile_batch
    label: "{{ inventory_hostname }} -> {{ profile_batch.profile_dir }} -> {{ profile_batch.jvms | join(',') }}"
  vars:
    profile_dir: "{{ profile_batch.profile_dir }}"
    profile_bin: "{{ profile_batch.profile_bin }}"
    jvm_owner: "{{ profile_batch.jvm_owner }}"
    profile_jvms: "{{ profile_batch.jvms | map('trim') | unique | list }}"
    profile_name_for_ps: "{{ profile_batch.profile_dir | basename }}"
  always:
    - name: Cleanup banners (always)
      include_tasks: banner_cleanup.yml
      when: (restart_banner_enabled | default(true)) | bool
roles/websphere_jvm_restart/tasks/discover_jvm.yml
---
# Inputs: jvm_name
# Output appended to discovered_jvms:
# { jvm_name, jvm_owner, profile_dir, profile_bin }

- name: Initialize discovery vars
  set_fact:
    _ps_line: ""
    _ps_lines: []
    _profile_dir: ""
    _jvm_owner: ""
    _profile_bin: ""
    discovered_profile_dir: ""
  changed_when: false

# --- PS lookup rules (profile name not available; best-effort) ---
- name: PS lookup for dmgr
  shell: "ps -ef | grep dmgr | grep -v grep"
  register: _ps
  changed_when: false
  failed_when: false
  when: (jvm_name | trim) == 'dmgr'

- name: PS lookup for nodeagent
  shell: "ps -ef | grep nodeagent | grep -v grep"
  register: _ps
  changed_when: false
  failed_when: false
  when: (jvm_name | trim) == 'nodeagent'

- name: PS lookup for appserver
  shell: "ps -ef | grep java | grep {{ (jvm_name | trim) | quote }} | grep -v grep"
  register: _ps
  changed_when: false
  failed_when: false
  when: (jvm_name | trim) not in ['dmgr','nodeagent']

- name: Pick first ps line if any
  set_fact:
    _ps_lines: "{{ _ps.stdout_lines | default([]) }}"
    _ps_line: "{{ (_ps.stdout_lines | default([]) | first | default('')) }}"
  changed_when: false

- name: If running, derive owner from ps
  set_fact:
    _jvm_owner: "{{ (_ps_line.split()[0] if (_ps_line | length > 0) else '') }}"
  changed_when: false

# --- Extract profile_dir from ps line if possible ---
- name: Extract profile_dir from ps line using /profiles/<name> pattern
  set_fact:
    _profile_dir: "{{ (_ps_line | regex_search('(/[^ ]*/profiles/[^/ ]+)', '\\1')) | default('') }}"
  changed_when: false

# If ps didn't give profile_dir, find it on disk (stopped JVM)
- name: Find profile for stopped JVM (filesystem search)
  include_tasks: find_profile_for_stopped_jvm.yml
  when: _profile_dir | length == 0
  vars:
    stopped_jvm_name: "{{ jvm_name | trim }}"

- name: Finalize profile_dir/owner/bin
  set_fact:
    _profile_dir: "{{ _profile_dir if (_profile_dir | length > 0) else discovered_profile_dir }}"
    _jvm_owner: "{{ _jvm_owner if (_jvm_owner | length > 0) else cached_install_owner }}"
    _profile_bin: "{{ _profile_dir ~ '/bin' }}"
  changed_when: false

- name: Validate discovered profile_dir
  assert:
    that:
      - _profile_dir | length > 0
    fail_msg: "Could not determine profile_dir for JVM {{ jvm_name }} on {{ inventory_hostname }}."

- name: Append discovered JVM
  set_fact:
    discovered_jvms: >-
      {{
        discovered_jvms + [
          {
            'jvm_name': (jvm_name | trim),
            'jvm_owner': _jvm_owner,
            'profile_dir': _profile_dir,
            'profile_bin': _profile_bin
          }
        ]
      }}
  changed_when: false
roles/websphere_jvm_restart/tasks/find_profile_for_stopped_jvm.yml
---
# Input: stopped_jvm_name
# Output: discovered_profile_dir + updates cached_install_root/cached_install_owner

- name: Populate install root cache if empty
  when: cached_install_root | length == 0
  block:
    - name: Check install roots
      stat:
        path: "{{ install_root }}"
      loop: "{{ was_install_roots }}"
      loop_control:
        loop_var: install_root
      register: install_root_stats

    - name: Select first existing install root
      set_fact:
        cached_install_root: >-
          {{
            (install_root_stats.results
              | selectattr('stat.exists','equalto',true)
              | map(attribute='install_root')
              | list
              | first) | default('')
          }}

    - name: Fail if no install root exists
      assert:
        that:
          - cached_install_root | length > 0
        fail_msg: "No WebSphere install root found on {{ inventory_hostname }}."

    - name: Determine cached owner
      stat:
        path: "{{ cached_install_root }}"
      register: cached_root_stat

    - set_fact:
        cached_install_owner: "{{ cached_root_stat.stat.pw_name | default('') }}"
    - when: cached_install_owner | length == 0
      block:
        - shell: "ls -ld {{ cached_install_root }} | awk '{print $3}'"
          register: cached_owner_cmd
          changed_when: false
        - set_fact:
            cached_install_owner: "{{ cached_owner_cmd.stdout | trim }}"

- name: Find servers/<jvm> under config and return first hit
  shell: >-
    find {{ cached_install_root | regex_replace('/$', '') }}/profiles -type d
    -path "*/config/cells/*/nodes/*/servers/{{ stopped_jvm_name }}" -print -quit
  register: _find_profile
  changed_when: false
  failed_when: false

- name: Extract discovered_profile_dir from found path
  set_fact:
    discovered_profile_dir: >-
      {{
        (_find_profile.stdout | trim)
        | regex_search('(.*/profiles/[^/]+)/config/.*', '\\1')
        | default('')
      }}

- name: Fail if profile for stopped JVM not found
  assert:
    that:
      - discovered_profile_dir | length > 0
    fail_msg: "Could not locate profile for stopped JVM {{ stopped_jvm_name }} under {{ cached_install_root }}/profiles."
