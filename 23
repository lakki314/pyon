roles/websphere_jvm_restart/tasks/restart_started_jvm.yml
---
# Uses sudo su - owner for stop/start to avoid AIX temp-file issues with async.
# PID lookup uses:
# - dmgr/nodeagent: grep profile_name_for_restart (basename of profile_dir)
# - appserver: grep java + jvm name

- name: Normalize JVM name for comparisons
  set_fact:
    started_jvm_norm: "{{ (started_jvm | string | trim) }}"
  changed_when: false

- name: Reset ps capture output for this JVM iteration
  set_fact:
    _ps_kill: { "stdout_lines": [] }
  changed_when: false

- name: Capture PID for DMGR
  shell: "ps -ef | grep dmgr | grep {{ profile_name_for_restart | quote }} | grep -v grep"
  register: _ps_kill
  changed_when: false
  failed_when: false
  when: started_jvm_norm == 'dmgr'

- name: Capture PID for NODEAGENT
  shell: "ps -ef | grep nodeagent | grep {{ profile_name_for_restart | quote }} | grep -v grep"
  register: _ps_kill
  changed_when: false
  failed_when: false
  when: started_jvm_norm == 'nodeagent'

- name: Capture PID for AppServer
  shell: "ps -ef | grep java | grep {{ started_jvm_norm | quote }} | grep -v grep"
  register: _ps_kill
  changed_when: false
  failed_when: false
  when: started_jvm_norm not in ['dmgr','nodeagent']

- name: Extract pid_to_kill (first line)
  set_fact:
    _pid_lines: "{{ _ps_kill.stdout_lines | default([]) }}"
    pid_to_kill: "{{ (_pid_lines | length > 0) | ternary((_pid_lines[0].split()[1]), '') }}"
  changed_when: false

- name: Ensure PID is known
  assert:
    that:
      - pid_to_kill | length > 0
    fail_msg: >-
      Cannot determine PID for {{ started_jvm_norm }} in profile {{ profile_name_for_restart }}.
      PS output: {{ _ps_kill.stdout_lines | default([]) }}

# STOP (no async)
- name: Stop NODEAGENT (sudo su - owner, background)
  shell: >-
    sudo su - {{ jvm_owner_for_restart }} -c
    "nohup {{ profile_bin_for_restart }}/stopNode.sh >/tmp/stopNode_{{ profile_name_for_restart }}.log 2>&1 &"
  become: true
  changed_when: true
  failed_when: false
  when: started_jvm_norm == 'nodeagent'

- name: Stop DMGR (sudo su - owner, background)
  shell: >-
    sudo su - {{ jvm_owner_for_restart }} -c
    "nohup {{ profile_bin_for_restart }}/stopManager.sh >/tmp/stopMgr_{{ profile_name_for_restart }}.log 2>&1 &"
  become: true
  changed_when: true
  failed_when: false
  when: started_jvm_norm == 'dmgr'

- name: Stop AppServer (sudo su - owner, background)
  shell: >-
    sudo su - {{ jvm_owner_for_restart }} -c
    "nohup {{ profile_bin_for_restart }}/stopServer.sh {{ started_jvm_norm }} >/tmp/stopSrv_{{ profile_name_for_restart }}_{{ started_jvm_norm }}.log 2>&1 &"
  become: true
  changed_when: true
  failed_when: false
  when: started_jvm_norm not in ['dmgr','nodeagent']

# PID poll / kill -9
- name: Wait up to timeout for PID to disappear (ps polling)
  block:
    - name: Poll ps until PID disappears
      shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
      register: pid_poll
      become: true
      changed_when: false
      failed_when: false
      retries: "{{ (stop_timeout_seconds // stop_check_delay) | int }}"
      delay: "{{ stop_check_delay }}"
      until: (pid_poll.stdout | default('') | trim) == ""
  rescue:
    - name: Kill -9 PID if still present
      shell: "kill -9 {{ pid_to_kill }}"
      become: true
      changed_when: true
      failed_when: false

    - name: Poll until PID disappears after kill -9
      shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
      register: pid_poll_after_kill
      become: true
      changed_when: false
      failed_when: false
      retries: 60
      delay: 5
      until: (pid_poll_after_kill.stdout | default('') | trim) == ""

- name: Final verify PID is gone before start
  shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
  register: pid_final_check
  become: true
  changed_when: false
  failed_when: false

- name: Assert PID is gone
  assert:
    that:
      - (pid_final_check.stdout | default('') | trim) == ""
    fail_msg: "PID {{ pid_to_kill }} still exists; will not start {{ started_jvm_norm }}."

# START
- name: Start NODEAGENT (sudo su - owner)
  shell: >-
    sudo su - {{ jvm_owner_for_restart }} -c
    "{{ profile_bin_for_restart }}/startNode.sh"
  become: true
  changed_when: true
  when: started_jvm_norm == 'nodeagent'

- name: Start DMGR (sudo su - owner)
  shell: >-
    sudo su - {{ jvm_owner_for_restart }} -c
    "{{ profile_bin_for_restart }}/startManager.sh"
  become: true
  changed_when: true
  when: started_jvm_norm == 'dmgr'

- name: Start AppServer (sudo su - owner)
  shell: >-
    sudo su - {{ jvm_owner_for_restart }} -c
    "{{ profile_bin_for_restart }}/startServer.sh {{ started_jvm_norm }}"
  become: true
  changed_when: true
  when: started_jvm_norm not in ['dmgr','nodeagent']
roles/websphere_jvm_restart/tasks/restart_profile.yml
---
# Inputs:
# profile_dir, profile_bin, jvm_owner, profile_jvms, profile_name_for_ps

- name: Debug - profile batch inputs
  when: wsjvm_debug | bool
  debug:
    msg:
      host: "{{ inventory_hostname }}"
      profile_dir: "{{ profile_dir }}"
      profile_bin: "{{ profile_bin }}"
      jvm_owner: "{{ jvm_owner }}"
      profile_jvms: "{{ profile_jvms }}"
      profile_name_for_ps: "{{ profile_name_for_ps }}"

# Banner
- name: Set host banner once for this owner
  when: (restart_banner_enabled | default(true)) | bool
  include_tasks: banner_set_host.yml
  vars:
    banner_owner: "{{ jvm_owner }}"
    banner_lines:
      - "RITM: {{ ritm_number }}"
      - "Timestamp: {{ lookup('pipe', 'date \"+%Y-%m-%d %H:%M:%S %Z\"') }}"
      - "Contact/Team: {{ wsjvm_contact_team }}"
      - "Change Window: {{ wsjvm_change_window }}"
      - "Environment: {{ env_name | default('na') }}"
      - "Host: {{ inventory_hostname }}"
      - "Profile: {{ profile_dir | basename }}"
      - "JVMs: {{ profile_jvms | join(', ') }}"

# serverStatus PRE
- name: Run serverStatus.sh -all (pre)
  shell: "{{ profile_bin }}/serverStatus.sh -all"
  register: server_status_pre
  become: true
  become_user: "{{ jvm_owner }}"
  changed_when: false
  failed_when: false

- name: Initialize pre classification lists
  set_fact:
    jvms_started_pre: []
    jvms_stopped_pre: []

- name: Classify each JVM (STARTED + STOPPED for AppServer/nodeagent/dmgr)
  set_fact:
    jvms_started_pre: "{{ jvms_started_pre + ([one_jvm_trim] if started_hit else []) }}"
    jvms_stopped_pre: "{{ jvms_stopped_pre + ([one_jvm_trim] if stopped_hit else []) }}"
  vars:
    one_jvm_trim: "{{ one_jvm | trim }}"
    started_hit: >-
      {{
        (
          (one_jvm_trim == 'nodeagent' and (server_status_pre.stdout | default('') | regex_search('ADMU0508I: The Node Agent \"nodeagent\" is STARTED')) is not none)
          or
          (one_jvm_trim == 'dmgr' and (server_status_pre.stdout | default('') | regex_search('ADMU0508I: The Deployment Manager \"dmgr\" is STARTED')) is not none)
          or
          (one_jvm_trim not in ['dmgr','nodeagent'] and (server_status_pre.stdout | default('') | regex_search('ADMU0508I: The Application Server \"' ~ (one_jvm_trim | regex_escape) ~ '\" is STARTED')) is not none)
        )
      }}
    stopped_hit: >-
      {{
        (
          (one_jvm_trim == 'nodeagent' and (server_status_pre.stdout | default('') | regex_search('ADMU0509I: The Node Agent \"nodeagent\" cannot be reached')) is not none)
          or
          (one_jvm_trim == 'dmgr' and (server_status_pre.stdout | default('') | regex_search('ADMU0509I: The Deployment Manager \"dmgr\" cannot be reached')) is not none)
          or
          (one_jvm_trim not in ['dmgr','nodeagent'] and (server_status_pre.stdout | default('') | regex_search('ADMU0509I: The Application Server \"' ~ (one_jvm_trim | regex_escape) ~ '\" cannot be reached')) is not none)
        )
      }}
  loop: "{{ profile_jvms }}"
  loop_control:
    loop_var: one_jvm
    label: "{{ inventory_hostname }} -> classify {{ one_jvm_trim }}"

- name: Ensure all JVMs classified (started+stopped must equal requested)
  assert:
    that:
      - (jvms_started_pre | length) + (jvms_stopped_pre | length) == (profile_jvms | length)
    fail_msg: >-
      Some JVMs were not found/classified in serverStatus output for profile {{ profile_dir | basename }}.
      Requested={{ profile_jvms }}, started={{ jvms_started_pre }}, stopped={{ jvms_stopped_pre }}

# Start stopped
- name: Start STOPPED JVMs
  include_tasks: start_one_jvm.yml
  loop: "{{ jvms_stopped_pre }}"
  loop_control:
    loop_var: stopped_jvm
    label: "{{ inventory_hostname }} -> start {{ stopped_jvm }}"

# Restart started
- name: Restart STARTED JVMs safely
  include_tasks: restart_started_jvm.yml
  loop: "{{ jvms_started_pre }}"
  loop_control:
    loop_var: started_jvm
    label: "{{ inventory_hostname }} -> restart {{ started_jvm }}"
  vars:
    jvm_owner_for_restart: "{{ jvm_owner }}"
    profile_bin_for_restart: "{{ profile_bin }}"
    profile_name_for_restart: "{{ profile_name_for_ps }}"

# Build expected STARTED lines
- name: Reset expected_started_lines
  set_fact:
    expected_started_lines: []
  changed_when: false

- name: Build expected STARTED lines for all JVMs in this profile
  include_tasks: build_expected_started_line_one.yml
  loop: "{{ profile_jvms | map('trim') | unique | list }}"
  loop_control:
    loop_var: expected_jvm

# Post wait (expected-lines membership)
- name: Wait until all JVMs are STARTED (post) - expected lines membership
  shell: "{{ profile_bin }}/serverStatus.sh -all"
  register: server_status_post
  become: true
  become_user: "{{ jvm_owner }}"
  changed_when: false
  failed_when: false
  retries: "{{ restart_wait_retries }}"
  delay: "{{ restart_wait_delay }}"
  vars:
    normalized_lines: >-
      {{
        (server_status_post.stdout_lines | default([]))
        | map('regex_replace', '\r', '')
        | map('regex_replace', '[ \t]+', ' ')
        | map('trim')
        | list
      }}
    normalized_expected: >-
      {{
        expected_started_lines
        | map('regex_replace', '\r', '')
        | map('regex_replace', '[ \t]+', ' ')
        | map('trim')
        | list
      }}
    present_count: "{{ normalized_expected | select('in', normalized_lines) | list | length }}"
    expected_count: "{{ normalized_expected | length }}"
    missing_started_lines: "{{ normalized_expected | reject('in', normalized_lines) | list }}"
  until: present_count == expected_count

- name: Debug - missing STARTED lines (post)
  when: wsjvm_debug | bool
  debug:
    msg:
      expected_count: "{{ expected_count }}"
      present_count: "{{ present_count }}"
      missing_started_lines: "{{ missing_started_lines }}"

# Record results
- name: Record results for each JVM
  include_tasks: record_one_jvm.yml
  loop: "{{ profile_jvms }}"
  loop_control:
    loop_var: result_jvm
    label: "{{ inventory_hostname }} -> record {{ result_jvm }}"
