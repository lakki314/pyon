✅ Payload: envs -> hosts -> [jvm1, jvm2, ...] (no profile)
✅ Role discovers profile per JVM (PS first, filesystem fallback)
✅ Batches by discovered profile, runs serverStatus.sh -all once per profile (pre/post)
✅ Correct STARTED lines for AppServer/nodeagent/dmgr
✅ record_one_jvm.yml sets started_ok for all 3 types
✅ Official red banner (creates .profile if missing, aligned output)
✅ AIX temp-dir setup at role level
✅ Aggregation + ServiceNow update

playbooks/auto_router.yml
---
- name: Detect payload and build inventory for selected automation
  hosts: localhost
  gather_facts: false

  vars:
    wsjvm_debug: false

    role_registry:
      - payload_var: "jvm_restart"
        role_name: "websphere_jvm_restart"
        group_prefix: "wsjvm_restart_targets"

      # ---- Future roles (commented example) ----
      # - payload_var: "ihs_restart"
      #   role_name: "ihs_restart_role"
      #   group_prefix: "ihs_restart_targets"

  tasks:
    - name: Find which payloads are defined at launch
      set_fact:
        matched_specs: >-
          {{
            role_registry
            | selectattr('payload_var', 'in', vars.keys() | list)
            | list
          }}

    - name: Validate exactly one supported payload is provided
      assert:
        that:
          - matched_specs | length == 1
        fail_msg: >-
          Expected exactly ONE supported payload at launch.
          Supported: {{ role_registry | map(attribute='payload_var') | list }}
          Received: {{
            (role_registry | map(attribute='payload_var') | list)
            | select('in', vars.keys() | list)
            | list
          }}

    - name: Select role spec
      set_fact:
        selected_payload_var_name: "{{ matched_specs[0].payload_var }}"
        selected_role_name: "{{ matched_specs[0].role_name }}"
        selected_group_prefix: "{{ matched_specs[0].group_prefix }}"
        wsjvm_debug_selected: "{{ wsjvm_debug | bool }}"

    - name: Build dynamic inventory for selected role
      include_role:
        name: "{{ selected_role_name }}"
        tasks_from: build_inventory.yml
      vars:
        role_payload_var_name: "{{ selected_payload_var_name }}"
        role_group_prefix: "{{ selected_group_prefix }}"
        wsjvm_debug: "{{ wsjvm_debug_selected }}"

    - name: Fail fast if no hosts were added
      assert:
        that:
          - (groups['wsjvm_restart_targets'] | default([]) | length) > 0
        fail_msg: "No hosts added to wsjvm_restart_targets. Check payload parsing or add_host."

- name: Execute selected role on payload hosts (parallel per host)
  hosts: wsjvm_restart_targets
  gather_facts: false
  strategy: free

  vars:
    selected_role_name: "{{ hostvars['localhost'].selected_role_name }}"
    wsjvm_debug_selected: "{{ hostvars['localhost'].wsjvm_debug_selected | default(false) }}"

  tasks:
    - name: Execute selected role on target hosts
      include_role:
        name: "{{ selected_role_name }}"
        tasks_from: execute_on_host.yml
      vars:
        wsjvm_debug: "{{ wsjvm_debug_selected }}"

- name: Aggregate results and notify ServiceNow
  hosts: localhost
  gather_facts: false

  vars:
    selected_role_name: "{{ hostvars['localhost'].selected_role_name }}"
    selected_payload_var_name: "{{ hostvars['localhost'].selected_payload_var_name }}"
    selected_group_prefix: "{{ hostvars['localhost'].selected_group_prefix }}"
    wsjvm_debug_selected: "{{ hostvars['localhost'].wsjvm_debug_selected | default(false) }}"

  tasks:
    - name: Aggregate and notify for selected role
      include_role:
        name: "{{ selected_role_name }}"
        tasks_from: aggregate_and_notify.yml
      vars:
        role_payload_var_name: "{{ selected_payload_var_name }}"
        role_group_prefix: "{{ selected_group_prefix }}"
        wsjvm_debug: "{{ wsjvm_debug_selected }}"
roles/websphere_jvm_restart/defaults/main.yml
---
role_payload_var_name: "jvm_restart"
role_group_prefix: "wsjvm_restart_targets"
wsjvm_debug: false

# Timing
restart_wait_retries: 30
restart_wait_delay: 10

stop_timeout_seconds: 600
stop_check_delay: 15

# Install root cache
was_install_roots:
  - "/opt/wps8/websphere/AppServer/85/"
  - "/opt/websphere/85/commonprofile/AppServer"
  - "/opt/websphere/90/commonprofile/AppServer"
  - "/opt/websphere/85/AppServer/"

# Remote tmp settings
wsjvm_remote_tmp: "/tmp/.ansible/tmp"
wsjvm_remote_tmp_mode: "1777"
wsjvm_enable_pipelining: true

# Banner
restart_banner_enabled: true
restart_banner_status_filename: ".was_jvm_restart_status"
restart_banner_profile_filename: ".profile"
restart_banner_block_id: "ANSIBLE MANAGED - WAS JVM RESTART BANNER"

wsjvm_contact_team: "Middleware Operations"
wsjvm_change_window: "As per approved change window"

# ServiceNow
snow_instance_url: ""
snow_update_path: ""
snow_validate_certs: true
snow_user: ""
snow_password: ""
snow_bearer_token: ""
roles/websphere_jvm_restart/tasks/build_inventory.yml
---
- name: Load payload
  set_fact:
    ws_payload: "{{ vars[role_payload_var_name] | default({}) }}"

- name: Validate payload exists
  assert:
    that:
      - ws_payload is mapping
      - ws_payload | length > 0
    fail_msg: "Payload var '{{ role_payload_var_name }}' is missing or empty."

- name: Extract ritm_number
  set_fact:
    ritm_number: >-
      {{
        ws_payload.get('ritm_number')
        or ws_payload.get('RITM number')
        or ws_payload.get('ritmNumber')
      }}

- name: Validate ritm_number
  assert:
    that:
      - ritm_number is defined
      - ritm_number | length > 0
    fail_msg: "ritm_number missing in payload."

- name: Extract envs map
  set_fact:
    envs_map: "{{ ws_payload.get('envs', {}) }}"

- name: Validate envs
  assert:
    that:
      - envs_map is mapping
      - envs_map | length > 0
    fail_msg: "payload.envs is missing/empty."

- name: Convert envs map to list
  set_fact:
    env_specs: "{{ envs_map | dict2items }}"

- name: Build dynamic inventory per env
  include_tasks: build_one_env.yml
  loop: "{{ env_specs }}"
  loop_control:
    loop_var: env_spec
    label: "{{ env_spec.key }}"
roles/websphere_jvm_restart/tasks/build_one_env.yml
---
- name: Set env context
  set_fact:
    env_name: "{{ env_spec.key }}"
    env_hosts_map: "{{ env_spec.value.get('hosts', {}) }}"

- name: Validate env hosts
  assert:
