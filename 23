---
- name: Ensure home directory exists
  file:
    path: "/home/{{ banner_owner }}"
    state: directory
    mode: "0755"
    owner: "{{ banner_owner }}"
  become: true
  failed_when: false

- name: Check if .profile exists
  stat:
    path: "/home/{{ banner_owner }}/{{ restart_banner_profile_filename }}"
  register: banner_profile_stat

- name: Create .profile if missing
  file:
    path: "/home/{{ banner_owner }}/{{ restart_banner_profile_filename }}"
    state: touch
    owner: "{{ banner_owner }}"
    mode: "0644"
  become: true
  when: not (banner_profile_stat.stat.exists | default(false))

- name: Ensure .profile prints banner when status file exists (RED + official + aligned)
  blockinfile:
    path: "/home/{{ banner_owner }}/{{ restart_banner_profile_filename }}"
    create: true
    owner: "{{ banner_owner }}"
    mode: "0644"
    marker: "# {mark} {{ restart_banner_block_id }}"
    block: |
      if [ -f "$HOME/{{ restart_banner_status_filename }}" ]; then
        RED="$(printf '\033[1;31m')"
        BOLD="$(printf '\033[1m')"
        RESET="$(printf '\033[0m')"

        echo "${RED}######################################################################${RESET}"
        echo "${RED}#${BOLD}                   OFFICIAL AUTOMATION NOTICE                        ${RESET}${RED}#${RESET}"
        echo "${RED}#${RESET}  WebSphere JVM restart is currently IN PROGRESS on this host.       ${RED}#${RESET}"
        echo "${RED}#${RESET}  Do not manually stop/start JVMs unless authorized by the change.   ${RED}#${RESET}"
        echo "${RED}######################################################################${RESET}"
        echo

        awk -v RED="${RED}" -v RESET="${RESET}" '
          BEGIN { pad=16 }
          {
            line=$0
            sub(/\r$/, "", line)
            if (match(line, /^[^:]+:[[:space:]]*/)) {
              key = substr(line, 1, index(line, ":")-1)
              val = substr(line, index(line, ":")+1)
              sub(/^[[:space:]]+/, "", val)
              gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
              printf("%s%-*s%s : %s\n", RED, pad, key, RESET, val)
            } else if (length(line) > 0) {
              printf("%s%-*s%s   %s\n", RED, pad, "", RESET, line)
            } else {
              print ""
            }
          }
        ' "$HOME/{{ restart_banner_status_filename }}"

        echo
        echo "${RED}######################################################################${RESET}"
      fi
  become: true

- name: Write banner status file
  copy:
    dest: "/home/{{ banner_owner }}/{{ restart_banner_status_filename }}"
    content: "{{ (banner_lines | default([banner_summary | default('')])) | join('\n') }}\n"
    owner: "{{ banner_owner }}"
    mode: "0644"
  become: true

- name: Track owners touched
  set_fact:
    owners_touched: "{{ owners_touched | union([banner_owner]) }}"
