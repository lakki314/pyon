1) Playbook: jvm_restart_websphere.yml
What it does

Reads jvm_restart.hosts and builds a dynamic group jvm_restart_targets

Flattens each host’s profiles/JVMs into restart_requests

Runs the role in parallel across hosts

Aggregates results and sends ONE ServiceNow update with:

status: failed if any JVM failed

failed_hosts: ["host:profile:jvm", ...]

---
- name: Build dynamic inventory from payload (host -> profile -> jvms)
  hosts: localhost
  gather_facts: false

  tasks:
    - name: Validate payload exists
      assert:
        that:
          - jvm_restart is defined
          - jvm_restart is mapping
        fail_msg: "Expected extra_vars to contain 'jvm_restart' as a dictionary."

    - name: Extract RITM number
      set_fact:
        ritm_number: >-
          {{
            jvm_restart.get('ritm_number')
            or jvm_restart.get('RITM number')
            or jvm_restart.get('ritmNumber')
          }}

    - name: Ensure RITM is present
      assert:
        that:
          - ritm_number is defined
          - ritm_number | length > 0
        fail_msg: "ritm_number is missing from payload."

    - name: Extract hosts map
      set_fact:
        hosts_map: "{{ jvm_restart.get('hosts', {}) }}"

    - name: Validate hosts map
      assert:
        that:
          - hosts_map is mapping
          - (hosts_map | length) > 0
        fail_msg: "Payload must contain jvm_restart.hosts as a mapping host -> profile -> [jvms]."

    - name: Add hosts to dynamic group with flattened restart_requests
      add_host:
        name: "{{ item.key }}"
        groups: "jvm_restart_targets"
        ritm_number: "{{ ritm_number }}"
        restart_requests: >-
          {%- set out = [] -%}
          {%- for p in (item.value | dict2items) -%}
            {%- for j in (p.value | default([])) -%}
              {%- set _ = out.append({'profile_name': p.key, 'jvm_name': j}) -%}
            {%- endfor -%}
          {%- endfor -%}
          {{ out }}
      loop: "{{ hosts_map | dict2items }}"

- name: Restart WebSphere JVMs in parallel per host
  hosts: jvm_restart_targets
  gather_facts: false
  strategy: free
  roles:
    - websphere_jvm_restart

- name: Aggregate results and send ONE ServiceNow update
  hosts: localhost
  gather_facts: false

  tasks:
    - name: Collect all JVM results from all hosts
      set_fact:
        all_jvm_results: "{{ (all_jvm_results | default([])) + (hostvars[item].jvm_results | default([])) }}"
      loop: "{{ groups['jvm_restart_targets'] | default([]) }}"

    - name: Build failed_hosts as ["host:profile:jvm", ...]
      set_fact:
        failed_hosts: >-
          {{
            (all_jvm_results | default([])
              | selectattr('status','equalto','failed')
              | map(attribute='host_profile_jvm')
              | list)
          }}

    - name: Determine overall status
      set_fact:
        overall_status: "{{ 'failed' if (failed_hosts | length > 0) else 'success' }}"
        success_count: "{{ (all_jvm_results | default([]) | selectattr('status','equalto','success') | list | length) }}"
        fail_count: "{{ failed_hosts | length }}"
        total_count: "{{ all_jvm_results | default([]) | length }}"

    - name: Build ServiceNow payload
      set_fact:
        snow_body_info:
          status: "{{ overall_status }}"
          ritm_number: "{{ ritm_number }}"
          failed_hosts: "{{ failed_hosts }}"
          message: >-
            JVM restart summary for RITM {{ ritm_number }}.
            Total: {{ total_count }}, Success: {{ success_count }}, Failed: {{ fail_count }}.

    - name: Send ServiceNow update (one call)
      include_role:
        name: websphere_jvm_restart
        tasks_from: snow_update.yml
