2) Post-restart wait using “expected lines membership” (NO difference)

Put this section in restart_profile.yml after start/restart actions and before recording results:

- name: Reset expected_started_lines
  set_fact:
    expected_started_lines: []
  changed_when: false

- name: Build expected STARTED lines for all JVMs in this profile
  include_tasks: build_expected_started_line_one.yml
  loop: "{{ profile_jvms | map('trim') | unique | list }}"
  loop_control:
    loop_var: expected_jvm
    label: "{{ expected_jvm }}"

- name: Wait until all JVMs are STARTED (post) - expected lines membership (no difference)
  shell: "{{ profile_bin }}/serverStatus.sh -all"
  register: server_status_post
  become: true
  become_user: "{{ jvm_owner }}"
  changed_when: false
  failed_when: false
  retries: "{{ restart_wait_retries }}"
  delay: "{{ restart_wait_delay }}"
  vars:
    normalized_lines: >-
      {{
        (server_status_post.stdout_lines | default([]))
        | map('regex_replace', '\r', '')
        | map('regex_replace', '[ \t]+', ' ')
        | map('trim')
        | list
      }}
    normalized_expected: >-
      {{
        expected_started_lines
        | map('regex_replace', '\r', '')
        | map('regex_replace', '[ \t]+', ' ')
        | map('trim')
        | list
      }}
    present_count: "{{ normalized_expected | select('in', normalized_lines) | list | length }}"
    expected_count: "{{ normalized_expected | length }}"
    missing_started_lines: "{{ normalized_expected | reject('in', normalized_lines) | list }}"
  until: present_count == expected_count

- name: Debug - missing STARTED lines (post)
  when: wsjvm_debug | bool
  debug:
    msg:
      profile: "{{ profile_name }}"
      expected_count: "{{ expected_count }}"
      present_count: "{{ present_count }}"
      missing_started_lines: "{{ missing_started_lines }}"
Why this is better
No set math (difference)
Very direct: “are all expected lines present?”
You get missing_started_lines for easy troubleshooting.
