3.3 Execute on host (FAST + lazy cache)
roles/websphere_jvm_restart/tasks/execute_on_host.yml
---
- name: Initialize per-host tracking
  set_fact:
    jvm_results: "{{ jvm_results | default([]) }}"
    owners_touched: "{{ owners_touched | default([]) }}"
    cached_install_root: "{{ cached_install_root | default('') }}"
    cached_install_owner: "{{ cached_install_owner | default('') }}"

- name: Debug - host received vars
  when: wsjvm_debug | bool
  debug:
    msg:
      host: "{{ inventory_hostname }}"
      env_name: "{{ env_name | default('') }}"
      ritm_number: "{{ ritm_number | default('') }}"
      restart_requests_count: "{{ (restart_requests | default([])) | length }}"

- name: Validate restart_requests exist
  assert:
    that:
      - restart_requests is defined
      - restart_requests is sequence
      - restart_requests | length > 0
    fail_msg: "No restart_requests on {{ inventory_hostname }}."

# Group requests by profile
- name: Initialize profile_map
  set_fact:
    profile_map: {}

- name: Build profile_map {profile_name: [jvm1,jvm2,...]}
  set_fact:
    profile_map: "{{ profile_map | combine({ req_profile: (profile_map.get(req_profile, []) + [req_jvm]) }) }}"
  vars:
    req_profile: "{{ req_entry.profile_name }}"
    req_jvm: "{{ req_entry.jvm_name }}"
  loop: "{{ restart_requests }}"
  loop_control:
    loop_var: req_entry
    label: "{{ req_entry.profile_name }} -> {{ req_entry.jvm_name }}"

- name: Convert profile_map to list
  set_fact:
    profile_specs: "{{ profile_map | dict2items }}"

- name: Process each profile (batched serverStatus)
  block:
    - name: Restart JVMs for one profile
      include_tasks: restart_profile.yml
      loop: "{{ profile_specs }}"
      loop_control:
        loop_var: profile_spec
        label: "{{ env_name | default('na') }}:{{ inventory_hostname }} -> {{ profile_spec.key }}"
  always:
    - name: Cleanup banners (always)
      include_tasks: banner_cleanup.yml
      when: restart_banner_enabled | bool
3.4 Restart one profile (ps vs cache + debug)
roles/websphere_jvm_restart/tasks/restart_profile.yml
---
- name: Set profile vars for this batch
  set_fact:
    profile_name: "{{ profile_spec.key }}"
    profile_jvms: "{{ profile_spec.value | default([]) }}"

- name: Validate JVM list for profile
  assert:
    that:
      - profile_jvms is sequence
      - profile_jvms | length > 0
    fail_msg: "No JVMs for profile {{ profile_name }} on {{ inventory_hostname }}."

# ---------------------------
# Try PS discovery: if ANY JVM is running, use ps-derived owner/path
# ---------------------------
- name: Try ps discovery for JVMs in this profile
  shell: "ps -ef | grep java | grep {{ discover_jvm }} | grep -v grep"
  register: ps_discover_cmd
  changed_when: false
  failed_when: false
  loop: "{{ profile_jvms }}"
  loop_control:
    loop_var: discover_jvm
    label: "{{ profile_name }} -> ps check {{ discover_jvm }}"

- name: Select first ps line ending with any JVM in this profile
  set_fact:
    ps_discover_lines: >-
      {{
        (ps_discover_cmd.results | default([]))
        | map(attribute='stdout_lines')
        | list
        | flatten
        | select('match', '.*\\s(' ~ (profile_jvms | map('regex_escape') | join('|')) ~ ')$')
        | list
      }}
    ps_found: "{{ (ps_discover_lines | length) > 0 }}"

- name: If ps found, derive owner + profile_bin from ps rule
  when: ps_found
  block:
    - set_fact:
        ps_words: "{{ ps_discover_lines[0].split() }}"
        jvm_owner: "{{ ps_words[0] }}"
        detected_config_path: "{{ ps_words[-4] }}"
        detected_cell_name: "{{ ps_words[-3] }}"
        detected_profile_name: "{{ ps_words[-2] }}"
        discovery_source: "ps"

    - name: Validate ps-derived profile matches profile
      assert:
        that:
          - detected_profile_name == profile_name
        fail_msg: "ps-derived profile {{ detected_profile_name }} != payload profile {{ profile_name }}"

    - set_fact:
        profile_dir: "{{ detected_config_path | regex_replace('\\/config$', '') }}"
        profile_bin: "{{ (detected_config_path | regex_replace('\\/config$', '')) ~ '/bin' }}"

# ---------------------------
# If no JVM is running, use cached install root/owner (populate cache once per host)
# ---------------------------
- name: If no ps found, populate cache and derive profile paths
  when: not ps_found
  block:
    - name: Populate cache only if empty
      when: cached_install_root | length == 0
      block:
        - name: Debug - populating install root cache (only needed when JVMs are down)
          when: wsjvm_debug | bool
          debug:
            msg: "No JVM running for profile {{ profile_name }}. Populating install root cache on {{ inventory_hostname }}."

        - name: Check install roots
          stat:
            path: "{{ install_root }}"
          loop: "{{ was_install_roots }}"
          loop_control:
            loop_var: install_root
          register: install_root_stats

        - name: Select first existing install root
          set_fact:
            cached_install_root: >-
              {{
                (install_root_stats.results
                  | selectattr('stat.exists','equalto',true)
                  | map(attribute='install_root')
                  | list
                  | first) | default('')
              }}

        - name: Fail if no install root exists
          assert:
            that:
              - cached_install_root | length > 0
            fail_msg: "No WebSphere install root found on {{ inventory_hostname }}."

        - name: Determine cached install owner
          stat:
            path: "{{ cached_install_root }}"
          register: cached_root_stat

        - name: Save cached install owner (fallback to ls if needed)
          block:
            - set_fact:
                cached_install_owner: "{{ cached_root_stat.stat.pw_name | default('') }}"
            - when: cached_install_owner | length == 0
              block:
                - shell: "ls -ld {{ cached_install_root }} | awk '{print $3}'"
                  register: cached_owner_cmd
                  changed_when: false
                - set_fact:
                    cached_install_owner: "{{ cached_owner_cmd.stdout | trim }}"

    - name: Use cached values for profile path/owner
      set_fact:
        jvm_owner: "{{ cached_install_owner }}"
        detected_cell_name: "unknown"
        profile_dir: "{{ (cached_install_root | regex_replace('\\/$', '')) ~ '/profiles/' ~ profile_name }}"
        profile_bin: "{{ (cached_install_root | regex_replace('\\/$', '')) ~ '/profiles/' ~ profile_name ~ '/bin' }}"
        discovery_source: "cache"

    - name: Validate profile_dir exists
      stat:
        path: "{{ profile_dir }}"
      register: profile_dir_stat

    - assert:
        that:
          - profile_dir_stat.stat.exists
        fail_msg: "Profile path not found: {{ profile_dir }}"

- name: Debug - discovery source and derived paths
  when: wsjvm_debug | bool
  debug:
    msg:
      host: "{{ inventory_hostname }}"
      env: "{{ env_name | default('') }}"
      profile: "{{ profile_name }}"
      discovery_source: "{{ discovery_source }}"
      jvm_owner: "{{ jvm_owner }}"
      profile_bin: "{{ profile_bin }}"
      cached_install_root: "{{ cached_install_root | default('') }}"
      cached_install_owner: "{{ cached_install_owner | default('') }}"

# Banner ONCE per profile batch (one write)
- name: Set host banner once for this owner
  when: restart_banner_enabled | bool
  include_tasks: banner_set_host.yml
  vars:
    banner_owner: "{{ jvm_owner }}"
    banner_summary: >-
      WebSphere JVM restart IN PROGRESS
      RITM: {{ ritm_number }}
      ENV: {{ env_name | default('na') }}
      Host: {{ inventory_hostname }}
      Profile: {{ profile_name }}
      JVMs: {{ profile_jvms | join(', ') }}

# serverStatus PRE (once)
- name: Run serverStatus.sh -all (pre)
  shell: "{{ profile_bin }}/serverStatus.sh -all"
  register: server_status_pre
  become: true
  become_user: "{{ jvm_owner }}"
  changed_when: false
  failed_when: false

- name: Classify JVMs from pre serverStatus
  set_fact:
    jvms_started_pre: []
    jvms_stopped_pre: []

- name: Classify each JVM
  set_fact:
    jvms_started_pre: "{{ jvms_started_pre + ([one_jvm] if started_hit else []) }}"
    jvms_stopped_pre: "{{ jvms_stopped_pre + ([one_jvm] if stopped_hit else []) }}"
  vars:
    started_hit: "{{ (server_status_pre.stdout | default('') | regex_search('ADMU0508I: The Application Server \"' ~ (one_jvm | regex_escape) ~ '\" is STARTED')) is not none }}"
    stopped_hit: "{{ (server_status_pre.stdout | default('') | regex_search('ADMU0509I: The Application Server \"' ~ (one_jvm | regex_escape) ~ '\" cannot be reached')) is not none }}"
  loop: "{{ profile_jvms }}"
  loop_control:
    loop_var: one_jvm
    label: "{{ profile_name }} -> classify {{ one_jvm }}"

- name: Debug - pre classification
  when: wsjvm_debug | bool
  debug:
    msg:
      profile: "{{ profile_name }}"
      started: "{{ jvms_started_pre }}"
      stopped: "{{ jvms_stopped_pre }}"

- name: Ensure all JVMs were classified
  assert:
    that:
      - (jvms_started_pre | length) + (jvms_stopped_pre | length) == (profile_jvms | length)
    fail_msg: "Some JVMs were not found/classified in serverStatus output for profile {{ profile_name }}."

# Actions: start stopped JVMs
- name: Start STOPPED JVMs
  shell: "{{ profile_bin }}/startServer.sh {{ stopped_jvm }}"
  become: true
  become_user: "{{ jvm_owner }}"
  changed_when: true
  loop: "{{ jvms_stopped_pre }}"
  loop_control:
    loop_var: stopped_jvm
    label: "{{ profile_name }} -> start {{ stopped_jvm }}"

# Actions: restart started JVMs (safe stop/kill/poll/start)
- name: Restart STARTED JVMs safely
  include_tasks: restart_started_jvm.yml
  loop: "{{ jvms_started_pre }}"
  loop_control:
    loop_var: started_jvm
    label: "{{ profile_name }} -> restart {{ started_jvm }}"
  vars:
    jvm_owner_for_restart: "{{ jvm_owner }}"
    profile_bin_for_restart: "{{ profile_bin }}"

# serverStatus POST wait (once, until ALL are STARTED)
- name: Wait until all JVMs are STARTED (post)
  shell: "{{ profile_bin }}/serverStatus.sh -all"
  register: server_status_post
  become: true
  become_user: "{{ jvm_owner }}"
  changed_when: false
  failed_when: false
  retries: "{{ restart_wait_retries }}"
  delay: "{{ restart_wait_delay }}"
  until: >-
    {{
      profile_jvms
      | map('regex_escape')
      | map('regex_replace', '^(.*)$', 'ADMU0508I: The Application Server \"\\1\" is STARTED')
      | map('regex_search', server_status_post.stdout | default(''))
      | select('!=', None)
      | list
      | length
      == (profile_jvms | length)
    }}

# Record results per JVM
- name: Record results for each JVM
  block:
    - name: Best-effort ps for pid/cell
      shell: "ps -ef | grep java | grep {{ result_jvm }} | grep -v grep"
      register: ps_after_jvm
      changed_when: false
      failed_when: false

    - name: Extract pid/cell best-effort and compute started_ok
      set_fact:
        ps_lines: "{{ ps_after_jvm.stdout_lines | default([]) | select('match', '.*\\s' ~ (result_jvm | regex_escape) ~ '$') | list }}"
        new_pid: "{{ (ps_lines | length > 0) | ternary((ps_lines[0].split()[1]), 'not found via ps') }}"
        cell_name: "{{ (ps_lines | length > 0) | ternary((ps_lines[0].split()[-3]), (detected_cell_name | default('unknown'))) }}"
        started_ok: "{{ (server_status_post.stdout | default('') | regex_search('ADMU0508I: The Application Server \"' ~ (result_jvm | regex_escape) ~ '\" is STARTED')) is not none }}"

    - name: Append per-JVM result
      set_fact:
        jvm_results: >-
          {{
            jvm_results + [
              {
                'env_name': (env_name | default('na')),
                'env_host_profile_jvm': ((env_name | default('na')) ~ ':' ~ inventory_hostname ~ ':' ~ profile_name ~ ':' ~ result_jvm),
                'status': ( 'success' if started_ok else 'failed' ),
                'profile_dir': (profile_dir | default('unknown')),
                'cell_name': (cell_name | default('unknown')),
                'new_pid': (new_pid | default('')),
                'action': ( 'restart' if (result_jvm in jvms_started_pre) else 'start' ),
                'reason': ( '' if started_ok else 'Not STARTED after operations (post serverStatus)' )
              }
            ]
          }}
  loop: "{{ profile_jvms }}"
  loop_control:
    loop_var: result_jvm
    label: "{{ profile_name }} -> result {{ result_jvm }}"
3.5 Restart STARTED JVM safely (unchanged logic)
roles/websphere_jvm_restart/tasks/restart_started_jvm.yml
---
- name: Capture PID for stop/kill
  shell: "ps -ef | grep java | grep {{ started_jvm }} | grep -v grep"
  register: ps_for_kill
  changed_when: false
  failed_when: false

- name: Extract pid_to_kill
  set_fact:
    kill_lines: "{{ ps_for_kill.stdout_lines | default([]) | select('match', '.*\\s' ~ (started_jvm | regex_escape) ~ '$') | list }}"
    pid_to_kill: "{{ (kill_lines | length > 0) | ternary((kill_lines[0].split()[1]), '') }}"

- name: Ensure PID is known
  assert:
    that:
      - pid_to_kill | length > 0
    fail_msg: "Cannot determine PID for {{ started_jvm }}; cannot enforce stop/kill."

- name: Stop server (async)
  shell: "{{ profile_bin_for_restart }}/stopServer.sh {{ started_jvm }}"
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  async: "{{ stop_timeout_seconds }}"
  poll: 0
  changed_when: true

- name: Wait up to timeout for PID to disappear (ps polling)
  block:
    - name: Poll ps until PID disappears
      shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
      register: pid_poll
      become: true
      become_user: "{{ jvm_owner_for_restart }}"
      changed_when: false
      failed_when: false
      retries: "{{ (stop_timeout_seconds // stop_check_delay) | int }}"
      delay: "{{ stop_check_delay }}"
      until: (pid_poll.stdout | default('') | trim) == ""
  rescue:
    - name: Kill -9 PID if still present
      shell: "kill -9 {{ pid_to_kill }}"
      become: true
      become_user: "{{ jvm_owner_for_restart }}"
      changed_when: true
      failed_when: false

    - name: Poll until PID disappears after kill -9
      shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
      register: pid_poll_after_kill
      become: true
      become_user: "{{ jvm_owner_for_restart }}"
      changed_when: false
      failed_when: false
      retries: 60
      delay: 5
      until: (pid_poll_after_kill.stdout | default('') | trim) == ""

- name: Final verify PID is gone before start
  shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
  register: pid_final_check
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  changed_when: false
  failed_when: false

- name: Assert PID is gone
  assert:
    that:
      - (pid_final_check.stdout | default('') | trim) == ""
    fail_msg: "PID {{ pid_to_kill }} still exists; will not start {{ started_jvm }}."

- name: Start server after confirmed stop
  shell: "{{ profile_bin_for_restart }}/startServer.sh {{ started_jvm }}"
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  changed_when: true
3.6 Banner host-level
roles/websphere_jvm_restart/tasks/banner_set_host.yml
---
- name: Determine banner owner home directory
  shell: "getent passwd {{ banner_owner }} | cut -d: -f6 || echo /home/{{ banner_owner }}"
  register: banner_owner_home_cmd
  changed_when: false
  failed_when: false

- name: Set banner paths
  set_fact:
    banner_profile_file: "{{ (banner_owner_home_cmd.stdout | trim) ~ '/' ~ restart_banner_profile_filename }}"
    banner_status_file: "{{ (banner_owner_home_cmd.stdout | trim) ~ '/' ~ restart_banner_status_filename }}"

- name: Ensure .profile prints banner when status file exists
  blockinfile:
    path: "{{ banner_profile_file }}"
    create: true
    marker: "# {mark} {{ restart_banner_block_id }}"
    block: |
      if [ -f "$HOME/{{ restart_banner_status_filename }}" ]; then
        echo "############################################################"
        cat "$HOME/{{ restart_banner_status_filename }}"
        echo "############################################################"
      fi
  become: true
  become_user: "{{ banner_owner }}"

- name: Write banner status file
  copy:
    dest: "{{ banner_status_file }}"
    mode: "0644"
    content: "{{ banner_summary }}\n"
  become: true
  become_user: "{{ banner_owner }}"

- name: Track owners touched
  set_fact:
    owners_touched: "{{ owners_touched | union([banner_owner]) }}"
roles/websphere_jvm_restart/tasks/banner_cleanup.yml
---
- name: Cleanup banner artifacts for all touched owners
  loop: "{{ owners_touched | default([]) }}"
  loop_control:
    loop_var: banner_owner
  block:
    - name: Determine banner_owner home directory
      shell: "getent passwd {{ banner_owner }} | cut -d: -f6 || echo /home/{{ banner_owner }}"
      register: banner_owner_home_cmd
      changed_when: false
      failed_when: false

    - name: Remove status file
      file:
        path: "{{ (banner_owner_home_cmd.stdout | trim) ~ '/' ~ restart_banner_status_filename }}"
        state: absent
      become: true
      become_user: "{{ banner_owner }}"

    - name: Remove managed .profile block
      blockinfile:
        path: "{{ (banner_owner_home_cmd.stdout | trim) ~ '/' ~ restart_banner_profile_filename }}"
        marker: "# {mark} {{ restart_banner_block_id }}"
        state: absent
      become: true
      become_user: "{{ banner_owner }}"
3.7 Aggregate + notify + ServiceNow
roles/websphere_jvm_restart/tasks/aggregate_and_notify.yml
---
- name: Load payload to get ritm_number
  set_fact:
    ws_payload: "{{ vars[role_payload_var_name] | default({}) }}"

- name: Extract ritm_number
  set_fact:
    ritm_number: >-
      {{
        ws_payload.get('ritm_number')
        or ws_payload.get('RITM number')
        or ws_payload.get('ritmNumber')
      }}

- name: Find role dynamic groups
  set_fact:
    role_dyn_groups: >-
      {{
        (groups.keys() | list)
        | select('match', '^' ~ (role_group_prefix | regex_escape) ~ '_')
        | list
      }}

- name: Collect results from all hosts in role groups
  set_fact:
    all_jvm_results: "{{ (all_jvm_results | default([])) + (hostvars[target_host].jvm_results | default([])) }}"
  loop: "{{ role_dyn_groups | map('extract', groups) | list | flatten }}"
  loop_control:
    loop_var: target_host
    label: "{{ target_host }}"

- name: Build failed_hosts list
  set_fact:
    failed_hosts: >-
      {{
        (all_jvm_results | default([])
          | selectattr('status','equalto','failed')
          | map(attribute='env_host_profile_jvm')
          | list)
      }}

- name: Compute summary
  set_fact:
    overall_status: "{{ 'failed' if (failed_hosts | length > 0) else 'success' }}"
    total_count: "{{ all_jvm_results | default([]) | length }}"
    success_count: "{{ (all_jvm_results | default([]) | selectattr('status','equalto','success') | list | length) }}"
    fail_count: "{{ failed_hosts | length }}"

- name: Debug - failed_hosts
  when: wsjvm_debug | bool
  debug:
    msg:
      failed_hosts: "{{ failed_hosts }}"
      total: "{{ total_count }}"
      success: "{{ success_count }}"
      failed: "{{ fail_count }}"

- name: Build ServiceNow body
  set_fact:
    snow_body_info:
      status: "{{ overall_status }}"
      ritm_number: "{{ ritm_number }}"
      failed_hosts: "{{ failed_hosts }}"
      message: >-
        JVM restart summary for RITM {{ ritm_number }}.
        Total: {{ total_count }}, Success: {{ success_count }}, Failed: {{ fail_count }}.

- name: Send ServiceNow update
  include_tasks: snow_update.yml
roles/websphere_jvm_restart/tasks/snow_update.yml
---
- name: Validate ServiceNow endpoint settings
  assert:
    that:
      - snow_instance_url | length > 0
      - snow_update_path | length > 0
    fail_msg: "snow_instance_url and snow_update_path must be set."

- name: Build headers
  set_fact:
    snow_headers: >-
      {{
        {
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        }
        | combine(
            (snow_bearer_token | length > 0)
            | ternary({'Authorization': 'Bearer ' ~ snow_bearer_token}, {})
          )
      }}

- name: POST update to ServiceNow
  uri:
    url: "{{ snow_instance_url }}{{ snow_update_path }}"
    method: POST
    headers: "{{ snow_headers }}"
    body_format: json
    body: "{{ snow_body_info }}"
    validate_certs: "{{ snow_validate_certs }}"
    force_basic_auth: "{{ (snow_user | length > 0) and (snow_password | length > 0) }}"
    user: "{{ snow_user | default(omit) }}"
    password: "{{ snow_password | default(omit) }}"
    status_code: [200, 201, 202, 204]
  no_log: true
4) Explanations: how ps vs cache works now
Case 1: JVM is running
ps_found = true in restart_profile.yml
We parse:
jvm_owner
profile_bin
cell_name
from ps last-4-words rule
No cache checks are done.

Debug will show:

discovery_source: ps
profile_bin: /.../profiles/AppSrv01/bin
jvm_owner: wasadmin
Case 2: JVM not running
ps_found = false
We populate cache only once per host:
find first existing install root
determine owner of that root
Then derive:
profile_dir = <root>/profiles/<profile>
profile_bin = <profile_dir>/bin

Debug will show:

discovery_source: cache
cached_install_root: /opt/websphere/85/commonprofile/AppServer
cached_install_owner: wasadmin
profile_bin: /opt/websphere/85/commonprofile/AppServer/profiles/AppSrv01/bin
5) How to enable debug at launch

In AWX/Controller extra_vars (or curl):

wsjvm_debug: true
jvm_restart:
  ritm_number: RITM1234
  envs:
    dev:
      hosts:
        test1:
          AppSrv01: [server1, server2]

If you want the debug to avoid printing full restart_requests (for huge payloads), I can change the router debug to only show counts + profile list.
