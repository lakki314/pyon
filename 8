2) Router playbook (FULL) + debug of created hosts/vars
playbooks/auto_router.yml
---
- name: Detect payload and build inventory for selected automation
  hosts: localhost
  gather_facts: false

  vars:
    wsjvm_debug: false  # set true at launch for debug

    role_registry:
      - payload_var: "jvm_restart"
        role_name: "websphere_jvm_restart"
        group_prefix: "wsjvm_restart_targets"

      # ---- FUTURE EXAMPLE (commented) ----
      # - payload_var: "ihs_restart"
      #   role_name: "ihs_restart_role"
      #   group_prefix: "ihs_restart_targets"

  tasks:
    - name: Find which payloads are defined at launch
      set_fact:
        matched_specs: >-
          {{
            role_registry
            | selectattr('payload_var', 'in', vars.keys() | list)
            | list
          }}

    - name: Validate exactly one supported payload is provided
      assert:
        that:
          - matched_specs | length == 1
        fail_msg: >-
          Expected exactly ONE supported payload at launch.
          Supported: {{ role_registry | map(attribute='payload_var') | list }}
          Received: {{
            (role_registry | map(attribute='payload_var') | list)
            | select('in', vars.keys() | list)
            | list
          }}

    - name: Select role spec
      set_fact:
        selected_payload_var_name: "{{ matched_specs[0].payload_var }}"
        selected_role_name: "{{ matched_specs[0].role_name }}"
        selected_group_prefix: "{{ matched_specs[0].group_prefix }}"

    - name: Build dynamic inventory for selected role
      include_role:
        name: "{{ selected_role_name }}"
        tasks_from: build_inventory.yml
      vars:
        role_payload_var_name: "{{ selected_payload_var_name }}"
        role_group_prefix: "{{ selected_group_prefix }}"

    # ---- DEBUG: show created groups + hosts + vars ----
    - name: Debug - show dynamic groups created
      when: wsjvm_debug | bool
      debug:
        msg:
          group_prefix: "{{ selected_group_prefix }}"
          dynamic_groups: >-
            {{
              (groups.keys() | list)
              | select('match', '^' ~ (selected_group_prefix | regex_escape) ~ '_')
              | list
            }}

    - name: Debug - show hosts per dynamic group
      when: wsjvm_debug | bool
      debug:
        msg:
          group: "{{ dyn_group }}"
          hosts: "{{ groups[dyn_group] | default([]) }}"
      loop: >-
        {{
          (groups.keys() | list)
          | select('match', '^' ~ (selected_group_prefix | regex_escape) ~ '_')
          | list
        }}
      loop_control:
        loop_var: dyn_group

    - name: Debug - show vars for each created host
      when: wsjvm_debug | bool
      debug:
        msg:
          host: "{{ dyn_host }}"
          env_name: "{{ hostvars[dyn_host].env_name | default('') }}"
          ritm_number: "{{ hostvars[dyn_host].ritm_number | default('') }}"
          restart_requests_count: "{{ (hostvars[dyn_host].restart_requests | default([])) | length }}"
          restart_requests: "{{ hostvars[dyn_host].restart_requests | default([]) }}"
      loop: >-
        {{
          (groups.keys() | list)
          | select('match', '^' ~ (selected_group_prefix | regex_escape) ~ '_')
          | map('extract', groups)
          | list
          | flatten
          | unique
        }}
      loop_control:
        loop_var: dyn_host

- name: Execute selected role on dynamic hosts (parallel per host)
  hosts: all
  gather_facts: false
  strategy: free

  vars:
    wsjvm_debug: "{{ hostvars['localhost'].wsjvm_debug | default(false) }}"
    selected_role_name: "{{ hostvars['localhost'].selected_role_name }}"
    selected_payload_var_name: "{{ hostvars['localhost'].selected_payload_var_name }}"
    selected_group_prefix: "{{ hostvars['localhost'].selected_group_prefix }}"

  tasks:
    - name: Execute selected role on hosts that belong to its groups
      include_role:
        name: "{{ selected_role_name }}"
        tasks_from: execute_on_host.yml
      vars:
        role_payload_var_name: "{{ selected_payload_var_name }}"
        role_group_prefix: "{{ selected_group_prefix }}"
        wsjvm_debug: "{{ wsjvm_debug }}"
      when: >
        (group_names | select('match', '^' ~ (selected_group_prefix | regex_escape) ~ '_') | list | length) > 0

- name: Aggregate results and notify ServiceNow (selected role only)
  hosts: localhost
  gather_facts: false

  vars:
    wsjvm_debug: "{{ hostvars['localhost'].wsjvm_debug | default(false) }}"
    selected_role_name: "{{ hostvars['localhost'].selected_role_name }}"
    selected_payload_var_name: "{{ hostvars['localhost'].selected_payload_var_name }}"
    selected_group_prefix: "{{ hostvars['localhost'].selected_group_prefix }}"

  tasks:
    - name: Aggregate and notify for selected role
      include_role:
        name: "{{ selected_role_name }}"
        tasks_from: aggregate_and_notify.yml
      vars:
        role_payload_var_name: "{{ selected_payload_var_name }}"
        role_group_prefix: "{{ selected_group_prefix }}"
        wsjvm_debug: "{{ wsjvm_debug }}"
