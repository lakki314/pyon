# roles/ihs_cert_deploy/tasks/main.yml
---
# IHS Cert Deploy Role - entrypoint
#
# Tags:
#   deploy -> plan-driven deploy (all eligible IHS certs/hosts)
#   retry  -> retry only failed hosts using ihs_failed_hosts_map + also runs report
#   report -> send report only (or included automatically with retry)
#
# Order:
# - deploy run:  deploy -> report -> fail_gate
# - retry run:   retry  -> report -> fail_gate
#
# Notes:
# - fail_gate always runs after report so the report is sent even when failing.
# - fail_gate publishes ihs_failed_hosts_map for AWX workflow retry node.

- name: ihs | assert venafi_cert_plan present
  assert:
    that:
      - venafi_cert_plan is defined
      - (venafi_cert_plan | length) > 0
    fail_msg: "ihs_cert_deploy requires venafi_cert_plan artifacts."
  run_once: true
  delegate_to: localhost
  tags: [deploy, retry, report]

# -------------------------------------------------------------------
# DEPLOY (plan-driven)
# -------------------------------------------------------------------
- name: ihs | deploy from plan
  import_tasks: deploy_from_plan.yml
  tags: [deploy]

# -------------------------------------------------------------------
# RETRY (failed hosts only)
# -------------------------------------------------------------------
- name: ihs | retry failed hosts
  import_tasks: retry.yml
  tags: [retry]

# -------------------------------------------------------------------
# REPORT
# - Runs when tag report is chosen
# - Also runs automatically with retry
# -------------------------------------------------------------------
- name: ihs | reporting (email)
  import_tasks: report.yml
  tags: [report, retry]

# -------------------------------------------------------------------
# FAIL GATE (STRICT)
# - after_import.status=failed is ALWAYS a failure (even if restore succeeds)
# - host.status=unknown is also a failure
# - publishes ihs_failed_hosts_map for AWX workflow retry node
# - fails job if any failures remain
# -------------------------------------------------------------------
- name: ihs | overall failure gate (strict)
  import_tasks: fail_gate.yml
  tags: [deploy, retry]
