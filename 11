---
- name: Capture PID for stop/kill (special dmgr/nodeagent)
  shell: >-
    {{
      (started_jvm == 'dmgr')
      | ternary(
          'ps -ef | grep dmgr | grep ' ~ (profile_name_for_restart | quote) ~ ' | grep -v grep',
          (started_jvm == 'nodeagent')
          | ternary(
              'ps -ef | grep nodeagent | grep ' ~ (profile_name_for_restart | quote) ~ ' | grep -v grep',
              'ps -ef | grep java | grep ' ~ (started_jvm | quote) ~ ' | grep -v grep'
          )
      )
    }}
  register: ps_for_kill
  changed_when: false
  failed_when: false

- name: Extract pid_to_kill
  set_fact:
    kill_lines: "{{ ps_for_kill.stdout_lines | default([]) }}"
    pid_to_kill: "{{ (kill_lines | length > 0) | ternary((kill_lines[0].split()[1]), '') }}"

- name: Ensure PID is known
  assert:
    that:
      - pid_to_kill | length > 0
    fail_msg: "Cannot determine PID for {{ started_jvm }} in profile {{ profile_name_for_restart }}."

- name: Stop JVM (async) (dmgr/nodeagent special)
  shell: >-
    {{
      (started_jvm == 'nodeagent')
      | ternary(profile_bin_for_restart ~ '/stopNode.sh',
        (started_jvm == 'dmgr')
        | ternary(profile_bin_for_restart ~ '/stopManager.sh',
          profile_bin_for_restart ~ '/stopServer.sh ' ~ started_jvm
        )
      )
    }}
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  async: "{{ stop_timeout_seconds }}"
  poll: 0
  changed_when: true

- name: Wait up to timeout for PID to disappear (ps polling)
  block:
    - name: Poll ps until PID disappears
      shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
      register: pid_poll
      become: true
      become_user: "{{ jvm_owner_for_restart }}"
      changed_when: false
      failed_when: false
      retries: "{{ (stop_timeout_seconds // stop_check_delay) | int }}"
      delay: "{{ stop_check_delay }}"
      until: (pid_poll.stdout | default('') | trim) == ""
  rescue:
    - name: Kill -9 PID if still present
      shell: "kill -9 {{ pid_to_kill }}"
      become: true
      become_user: "{{ jvm_owner_for_restart }}"
      changed_when: true
      failed_when: false

    - name: Poll until PID disappears after kill -9
      shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
      register: pid_poll_after_kill
      become: true
      become_user: "{{ jvm_owner_for_restart }}"
      changed_when: false
      failed_when: false
      retries: 60
      delay: 5
      until: (pid_poll_after_kill.stdout | default('') | trim) == ""

- name: Final verify PID is gone before start
  shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
  register: pid_final_check
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  changed_when: false
  failed_when: false

- name: Assert PID is gone
  assert:
    that:
      - (pid_final_check.stdout | default('') | trim) == ""
    fail_msg: "PID {{ pid_to_kill }} still exists; will not start {{ started_jvm }}."

- name: Start JVM after confirmed stop (dmgr/nodeagent special)
  shell: >-
    {{
      (started_jvm == 'nodeagent')
      | ternary(profile_bin_for_restart ~ '/startNode.sh',
        (started_jvm == 'dmgr')
        | ternary(profile_bin_for_restart ~ '/startManager.sh',
          profile_bin_for_restart ~ '/startServer.sh ' ~ started_jvm
        )
      )
    }}
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  changed_when: true
3.6 NEW file to record one JVM (Fix for loop over block)
roles/websphere_jvm_restart/tasks/record_one_jvm.yml
---
# Expects from restart_profile.yml context:
# profile_name, profile_dir, profile_bin, profile_jvms
# jvm_owner, env_name, server_status_post, jvms_started_pre, detected_cell_name
# result_jvm (loop var)

- name: Best-effort ps for pid/cell (dmgr/nodeagent special)
  shell: >-
    {{
      (result_jvm == 'dmgr')
      | ternary(
          'ps -ef | grep dmgr | grep ' ~ (profile_name | quote) ~ ' | grep -v grep',
          (result_jvm == 'nodeagent')
          | ternary(
              'ps -ef | grep nodeagent | grep ' ~ (profile_name | quote) ~ ' | grep -v grep',
              'ps -ef | grep java | grep ' ~ (result_jvm | quote) ~ ' | grep -v grep'
          )
      )
    }}
  register: ps_after_jvm
  changed_when: false
  failed_when: false

- name: Extract pid/cell best-effort and started_ok
  set_fact:
    ps_lines: "{{ ps_after_jvm.stdout_lines | default([]) }}"
    new_pid: "{{ (ps_lines | length > 0) | ternary((ps_lines[0].split()[1]), 'not found via ps') }}"
    cell_name: "{{ (ps_lines | length > 0) | ternary((ps_lines[0].split()[-3]), (detected_cell_name | default('unknown'))) }}"
    started_ok: "{{ (server_status_post.stdout | default('') | regex_search('ADMU0508I: The Application Server \"' ~ (result_jvm | regex_escape) ~ '\" is STARTED')) is not none }}"

- name: Append per-JVM result
  set_fact:
    jvm_results: >-
      {{
        jvm_results + [
          {
            'env_name': (env_name | default('na')),
            'env_host_profile_jvm': ((env_name | default('na')) ~ ':' ~ inventory_hostname ~ ':' ~ profile_name ~ ':' ~ result_jvm),
            'status': ( 'success' if started_ok else 'failed' ),
            'profile_dir': (profile_dir | default('unknown')),
            'cell_name': (cell_name | default('unknown')),
            'new_pid': (new_pid | default('')),
            'action': ( 'restart' if (result_jvm in jvms_started_pre) else 'start' ),
            'reason': ( '' if started_ok else 'Not STARTED after operations (post serverStatus)' )
          }
        ]
      }}
3.7 Banner tasks
roles/websphere_jvm_restart/tasks/banner_set_host.yml
---
- name: Determine banner owner home directory
  shell: "getent passwd {{ banner_owner }} | cut -d: -f6 || echo /home/{{ banner_owner }}"
  register: banner_owner_home_cmd
  changed_when: false
  failed_when: false

- name: Set banner paths
  set_fact:
    banner_profile_file: "{{ (banner_owner_home_cmd.stdout | trim) ~ '/' ~ restart_banner_profile_filename }}"
    banner_status_file: "{{ (banner_owner_home_cmd.stdout | trim) ~ '/' ~ restart_banner_status_filename }}"

- name: Ensure .profile prints banner when status file exists
  blockinfile:
    path: "{{ banner_profile_file }}"
    create: true
    marker: "# {mark} {{ restart_banner_block_id }}"
    block: |
      if [ -f "$HOME/{{ restart_banner_status_filename }}" ]; then
        echo "############################################################"
        cat "$HOME/{{ restart_banner_status_filename }}"
        echo "############################################################"
      fi
  become: true
  become_user: "{{ banner_owner }}"

- name: Write banner status file
  copy:
    dest: "{{ banner_status_file }}"
    mode: "0644"
    content: "{{ banner_summary }}\n"
  become: true
  become_user: "{{ banner_owner }}"

- name: Track owners touched
  set_fact:
    owners_touched: "{{ owners_touched | union([banner_owner]) }}"
roles/websphere_jvm_restart/tasks/banner_cleanup.yml
---
- name: Cleanup banner artifacts for all touched owners
  loop: "{{ owners_touched | default([]) }}"
  loop_control:
    loop_var: banner_owner
  block:
    - name: Determine banner_owner home directory
      shell: "getent passwd {{ banner_owner }} | cut -d: -f6 || echo /home/{{ banner_owner }}"
      register: banner_owner_home_cmd
      changed_when: false
      failed_when: false

    - name: Remove status file
      file:
        path: "{{ (banner_owner_home_cmd.stdout | trim) ~ '/' ~ restart_banner_status_filename }}"
        state: absent
      become: true
      become_user: "{{ banner_owner }}"

    - name: Remove managed .profile block
      blockinfile:
        path: "{{ (banner_owner_home_cmd.stdout | trim) ~ '/' ~ restart_banner_profile_filename }}"
        marker: "# {mark} {{ restart_banner_block_id }}"
        state: absent
      become: true
      become_user: "{{ banner_owner }}"
3.8 Aggregate + notify
roles/websphere_jvm_restart/tasks/aggregate_and_notify.yml
---
- name: Load payload to get ritm_number
  set_fact:
    ws_payload: "{{ vars[role_payload_var_name] | default({}) }}"

- name: Extract ritm_number
  set_fact:
    ritm_number: >-
      {{
        ws_payload.get('ritm_number')
        or ws_payload.get('RITM number')
        or ws_payload.get('ritmNumber')
      }}

- name: Find role dynamic groups
  set_fact:
    role_dyn_groups: >-
      {{
        (groups.keys() | list)
        | select('match', '^' ~ (role_group_prefix | regex_escape) ~ '_')
        | list
      }}

- name: Collect results from all hosts in role groups
  set_fact:
    all_jvm_results: "{{ (all_jvm_results | default([])) + (hostvars[target_host].jvm_results | default([])) }}"
  loop: "{{ role_dyn_groups | map('extract', groups) | list | flatten }}"
  loop_control:
    loop_var: target_host
    label: "{{ target_host }}"

- name: Build failed_hosts list
  set_fact:
    failed_hosts: >-
      {{
        (all_jvm_results | default([])
          | selectattr('status','equalto','failed')
          | map(attribute='env_host_profile_jvm')
          | list)
      }}

- name: Compute summary
  set_fact:
    overall_status: "{{ 'failed' if (failed_hosts | length > 0) else 'success' }}"
    total_count: "{{ all_jvm_results | default([]) | length }}"
    success_count: "{{ (all_jvm_results | default([]) | selectattr('status','equalto','success') | list | length) }}"
    fail_count: "{{ failed_hosts | length }}"

- name: Build ServiceNow body
  set_fact:
    snow_body_info:
      status: "{{ overall_status }}"
      ritm_number: "{{ ritm_number }}"
      failed_hosts: "{{ failed_hosts }}"
      message: >-
        JVM restart summary for RITM {{ ritm_number }}.
        Total: {{ total_count }}, Success: {{ success_count }}, Failed: {{ fail_count }}.

- name: Send ServiceNow update
  include_tasks: snow_update.yml
roles/websphere_jvm_restart/tasks/snow_update.yml
---
- name: Validate ServiceNow endpoint settings
  assert:
    that:
      - snow_instance_url | length > 0
      - snow_update_path | length > 0
    fail_msg: "snow_instance_url and snow_update_path must be set."

- name: Build headers
  set_fact:
    snow_headers: >-
      {{
        {
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        }
        | combine(
            (snow_bearer_token | length > 0)
            | ternary({'Authorization': 'Bearer ' ~ snow_bearer_token}, {})
          )
      }}

- name: POST update to ServiceNow
  uri:
    url: "{{ snow_instance_url }}{{ snow_update_path }}"
    method: POST
    headers: "{{ snow_headers }}"
    body_format: json
    body: "{{ snow_body_info }}"
    validate_certs: "{{ snow_validate_certs }}"
    force_basic_auth: "{{ (snow_user | length > 0) and (snow_password | length > 0) }}"
    user: "{{ snow_user | default(omit) }}"
    password: "{{ snow_password | default(omit) }}"
    status_code: [200, 201, 202, 204]
  no_log: true
Key explanation (what changed)
The invalid part was: loop on a block:. That’s not supported in Ansible.
We fixed it by moving the “record result” multi-task sequence into record_one_jvm.yml and looping include_tasks.

This is the canonical Ansible pattern and works cleanly in AWX/Controller.

If you want, I can also add a wsjvm_debug_compact: true mode to print only counts (not full restart_requests).
