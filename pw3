"""
WebSphere Admin Script to Update J2C Authentication Alias Password
Compatible with WebSphere Application Server 8.5.5.25

This script searches for a specific username in all J2C authentication aliases
and updates the password. Changes are synchronized to all nodes.
Includes validation by testing datasource connections that use the updated aliases.

Usage: wsadmin -lang jython -f update_j2c_password.py <username> <new_password>
"""

import sys

def log(message):
    """Print log message"""
    print("[INFO] %s" % message)

def get_username_input():
    """Get username from command line arguments"""
    if len(sys.argv) > 1:
        return sys.argv[0]
    else:
        log("ERROR: Username not provided")
        log("Usage: wsadmin -lang jython -f update_j2c_password.py <username> <new_password>")
        sys.exit(1)

def get_password_input():
    """Get password from command line arguments"""
    if len(sys.argv) > 2:
        return sys.argv[1]
    else:
        log("ERROR: Password not provided")
        log("Usage: wsadmin -lang jython -f update_j2c_password.py <username> <new_password>")
        sys.exit(1)

def get_all_j2c_aliases():
    """Get all J2C authentication aliases in the cell - WAS 8.5.5 compatible"""
    aliases = []
    
    try:
        # Get security configuration
        security = AdminConfig.list('Security')
        
        if not security:
            log("WARNING: Security configuration not found")
            return aliases
        
        # Get JAASAuthData (J2C Authentication Data entries)
        jaas_auth_data_list = AdminConfig.list('JAASAuthData', security)
        
        if jaas_auth_data_list:
            jaas_auth_data = jaas_auth_data_list.splitlines()
        else:
            jaas_auth_data = []
        
        log("Found %d J2C authentication alias(es)" % len(jaas_auth_data))
        
        return jaas_auth_data
        
    except Exception, e:
        log("ERROR: Failed to retrieve J2C authentication aliases: %s" % str(e))
        return aliases

def update_j2c_password(alias, username, new_password):
    """Update password for a J2C authentication alias - WAS 8.5.5 compatible"""
    try:
        alias_name = AdminConfig.showAttribute(alias, 'alias')
        current_user = AdminConfig.showAttribute(alias, 'userId')
        
        if current_user == username:
            log("  Found matching username in alias: %s" % alias_name)
            
            # Update the password
            AdminConfig.modify(alias, [['password', new_password]])
            log("  Password updated successfully for alias: %s" % alias_name)
            return True
        
        return False
        
    except Exception, e:
        log("  ERROR: Failed to update alias: %s" % str(e))
        return False

def get_all_datasources():
    """Get all datasources across all scopes - WAS 8.5.5 compatible"""
    datasources = []
    
    try:
        # Get all cells
        cells_list = AdminConfig.list('Cell')
        cells = cells_list.splitlines() if cells_list else []
        
        for cell in cells:
            # Get all nodes in the cell
            nodes_list = AdminConfig.list('Node', cell)
            nodes = nodes_list.splitlines() if nodes_list else []
            
            for node in nodes:
                # Get datasources at node scope
                node_ds_list = AdminConfig.list('DataSource', node)
                if node_ds_list:
                    datasources.extend(node_ds_list.splitlines())
            
            # Get datasources at cell scope
            cell_ds_list = AdminConfig.list('DataSource', cell)
            if cell_ds_list:
                datasources.extend(cell_ds_list.splitlines())
        
        # Get datasources at server scope
        servers_list = AdminConfig.list('Server')
        servers = servers_list.splitlines() if servers_list else []
        
        for server in servers:
            server_ds_list = AdminConfig.list('DataSource', server)
            if server_ds_list:
                datasources.extend(server_ds_list.splitlines())
        
        # Remove duplicates and empty entries
        unique_datasources = []
        seen = set()
        for ds in datasources:
            if ds and ds not in seen:
                unique_datasources.append(ds)
                seen.add(ds)
        
        return unique_datasources
        
    except Exception, e:
        log("ERROR: Failed to retrieve datasources: %s" % str(e))
        return []

def get_datasources_using_alias(alias_name):
    """Find all datasources that use a specific J2C authentication alias - WAS 8.5.5 compatible"""
    datasources_using_alias = []
    
    log("\n  Searching for datasources using alias: %s" % alias_name)
    
    all_datasources = get_all_datasources()
    
    for datasource in all_datasources:
        if datasource:
            try:
                ds_name = AdminConfig.showAttribute(datasource, 'name')
                
                # Check authDataAlias attribute (container-managed)
                auth_alias = AdminConfig.showAttribute(datasource, 'authDataAlias')
                
                if auth_alias and alias_name in auth_alias:
                    datasources_using_alias.append((datasource, ds_name))
                    log("    Found datasource (container-managed): %s" % ds_name)
                    continue
                
                # Check component-managed authentication alias
                mapping = AdminConfig.showAttribute(datasource, 'mapping')
                if mapping:
                    cm_auth_alias = AdminConfig.showAttribute(mapping, 'authDataAlias')
                    if cm_auth_alias and alias_name in cm_auth_alias:
                        datasources_using_alias.append((datasource, ds_name))
                        log("    Found datasource (component-managed): %s" % ds_name)
                    
            except Exception, e:
                # Silently skip datasources that can't be checked
                pass
    
    return datasources_using_alias

def test_datasource_connection(datasource, ds_name):
    """Test connection for a datasource - WAS 8.5.5 compatible"""
    try:
        # Get the datasource MBean
        ds_mbean_query = AdminControl.queryNames('type=DataSource,name=%s,*' % ds_name)
        
        if not ds_mbean_query:
            log("    WARNING: DataSource MBean not found for '%s' (server may not be running)" % ds_name)
            return 'skipped_server_not_running'
        
        # Handle multiple MBeans (if datasource exists on multiple servers)
        ds_mbeans = ds_mbean_query.splitlines() if ds_mbean_query else []
        
        test_results = []
        for mbean in ds_mbeans:
            if mbean:
                try:
                    log("    Testing connection for '%s'..." % ds_name)
                    result = AdminControl.invoke(mbean, 'testConnection')
                    
                    if result and 'Successful' in result:
                        log("    SUCCESS: Connection test passed for '%s'" % ds_name)
                        test_results.append('passed')
                    else:
                        log("    FAILED: Connection test failed for '%s'" % ds_name)
                        if result:
                            log("    Result: %s" % result)
                        test_results.append('failed')
                except Exception, e:
                    error_msg = str(e)
                    # Check for WAS_INSTALL_ROOT error
                    if 'WAS_INSTALL_ROOT' in error_msg or 'Undefined variable' in error_msg:
                        log("    SKIPPED: Undefined variable WAS_INSTALL_ROOT for '%s' - skipping to next" % ds_name)
                        test_results.append('skipped_was_install_root')
                    else:
                        log("    ERROR: Exception during connection test for '%s': %s" % (ds_name, error_msg))
                        test_results.append('failed')
        
        # Return the first result (prioritize passed, then failed, then skipped)
        if 'passed' in test_results:
            return 'passed'
        elif 'failed' in test_results:
            return 'failed'
        elif 'skipped_was_install_root' in test_results:
            return 'skipped_was_install_root'
        return 'skipped_server_not_running'
        
    except Exception, e:
        error_msg = str(e)
        if 'WAS_INSTALL_ROOT' in error_msg or 'Undefined variable' in error_msg:
            log("    SKIPPED: Undefined variable WAS_INSTALL_ROOT for '%s'" % ds_name)
            return 'skipped_was_install_root'
        log("    ERROR: Failed to test connection for '%s': %s" % (ds_name, error_msg))
        return 'failed'

def validate_updated_aliases(updated_aliases):
    """Validate password changes by testing datasource connections - WAS 8.5.5 compatible"""
    log("\n" + "=" * 70)
    log("Validating Password Changes - Testing Datasource Connections")
    log("=" * 70)
    
    if not updated_aliases:
        log("No aliases were updated, skipping validation")
        return {}
    
    # Track results per alias
    validation_results = {}
    
    for alias_name in updated_aliases:
        log("\nValidating alias: %s" % alias_name)
        
        # Find datasources using this alias
        datasources = get_datasources_using_alias(alias_name)
        
        if not datasources:
            log("  No datasources found using this alias")
            validation_results[alias_name] = {
                'datasources': [],
                'total': 0,
                'passed': 0,
                'failed': 0,
                'skipped_server': 0,
                'skipped_was_root': 0
            }
            continue
        
        log("  Found %d datasource(s) using this alias" % len(datasources))
        
        # Initialize results for this alias
        alias_results = {
            'datasources': [],
            'total': len(datasources),
            'passed': 0,
            'failed': 0,
            'skipped_server': 0,
            'skipped_was_root': 0
        }
        
        # Test each datasource
        for datasource, ds_name in datasources:
            result = test_datasource_connection(datasource, ds_name)
            
            ds_result = {'name': ds_name, 'status': result}
            alias_results['datasources'].append(ds_result)
            
            if result == 'passed':
                alias_results['passed'] = alias_results['passed'] + 1
            elif result == 'failed':
                alias_results['failed'] = alias_results['failed'] + 1
            elif result == 'skipped_was_install_root':
                alias_results['skipped_was_root'] = alias_results['skipped_was_root'] + 1
            else:  # skipped_server_not_running
                alias_results['skipped_server'] = alias_results['skipped_server'] + 1
        
        validation_results[alias_name] = alias_results
    
    return validation_results

def print_detailed_summary(updated_alias_names, validation_results):
    """Print detailed summary of all changes and test results"""
    log("\n" + "=" * 70)
    log("DETAILED SUMMARY OF CHANGES")
    log("=" * 70)
    
    if not updated_alias_names:
        log("No changes were made")
        return
    
    # Calculate totals
    total_aliases = len(updated_alias_names)
    total_datasources = 0
    total_passed = 0
    total_failed = 0
    total_skipped_server = 0
    total_skipped_was_root = 0
    
    log("\n1. J2C Authentication Aliases Updated: %d" % total_aliases)
    log("-" * 70)
    
    for alias_name in updated_alias_names:
        log("  - %s" % alias_name)
        
        if alias_name in validation_results:
            results = validation_results[alias_name]
            total_datasources = total_datasources + results['total']
            total_passed = total_passed + results['passed']
            total_failed = total_failed + results['failed']
            total_skipped_server = total_skipped_server + results['skipped_server']
            total_skipped_was_root = total_skipped_was_root + results['skipped_was_root']
            
            if results['total'] > 0:
                log("    Associated Datasources: %d" % results['total'])
                for ds in results['datasources']:
                    status_display = ds['status'].replace('_', ' ').upper()
                    log("      * %s: %s" % (ds['name'], status_display))
    
    log("\n2. Datasource Connection Test Results:")
    log("-" * 70)
    log("  Total datasources tested: %d" % total_datasources)
    log("  Passed: %d" % total_passed)
    log("  Failed: %d" % total_failed)
    log("  Skipped (server not running): %d" % total_skipped_server)
    log("  Skipped (WAS_INSTALL_ROOT error): %d" % total_skipped_was_root)
    
    log("\n3. Overall Status:")
    log("-" * 70)
    
    if total_failed > 0:
        log("  STATUS: WARNING - Some connection tests failed")
        log("  ACTION REQUIRED:")
        log("    - Verify the new password is correct")
        log("    - Check database server accessibility")
        log("    - Review failed datasource configurations")
        log("    - Check database account status (not locked)")
    elif total_passed > 0:
        log("  STATUS: SUCCESS - All tested connections passed")
        log("  Password update validated successfully")
    elif total_skipped_server > 0 or total_skipped_was_root > 0:
        log("  STATUS: INCOMPLETE - All tests were skipped")
        log("  ACTION REQUIRED:")
        log("    - Start application servers to test connections")
        log("    - Manually test datasource connections from admin console")
    else:
        log("  STATUS: NO DATASOURCES - No datasources use these aliases")
        log("  Password updated but no validation performed")
    
    log("\n" + "=" * 70)

def sync_all_nodes():
    """Synchronize all active nodes in the cell - WAS 8.5.5 compatible"""
    log("\n" + "=" * 70)
    log("Synchronizing all active nodes...")
    log("=" * 70)
    
    try:
        # Get all nodes
        nodes_list = AdminConfig.list('Node')
        nodes = nodes_list.splitlines() if nodes_list else []
        
        if not nodes:
            log("  No nodes found to synchronize")
            return True
        
        synced_count = 0
        failed_nodes = []
        
        for node in nodes:
            node_name = AdminConfig.showAttribute(node, 'name')
            
            # Skip the deployment manager node
            node_name_lower = node_name.lower()
            if 'dmgr' in node_name_lower or 'manager' in node_name_lower:
                log("  Skipping deployment manager node: %s" % node_name)
                continue
            
            try:
                # Check if node is synchronized
                sync_status = AdminControl.completeObjectName('type=NodeSync,node=%s,*' % node_name)
                
                if sync_status:
                    log("  Synchronizing node: %s" % node_name)
                    AdminControl.invoke(sync_status, 'sync')
                    synced_count = synced_count + 1
                    log("  Node '%s' synchronized successfully" % node_name)
                else:
                    log("  Node '%s' is not active or cannot be synchronized" % node_name)
                    failed_nodes.append(node_name)
            except Exception, e:
                log("  WARNING: Failed to sync node '%s': %s" % (node_name, str(e)))
                failed_nodes.append(node_name)
        
        log("\nSynchronization Summary:")
        log("  Successfully synced: %d node(s)" % synced_count)
        if failed_nodes:
            log("  Failed/Inactive nodes: %s" % ", ".join(failed_nodes))
        
        return len(failed_nodes) == 0
        
    except Exception, e:
        log("WARNING: Error during node synchronization: %s" % str(e))
        log("You may need to manually synchronize nodes from the admin console")
        return False

def main():
    """Main execution function - WAS 8.5.5 compatible"""
    log("=" * 70)
    log("J2C Authentication Alias Password Update Script")
    log("WebSphere Application Server 8.5.5.25 Compatible")
    log("=" * 70)
    
    # Get username and password from arguments
    username = get_username_input()
    new_password = get_password_input()
    
    log("\nConfiguration:")
    log("  Target Username: %s" % username)
    log("  New Password: %s" % ("*" * len(new_password)))
    log("=" * 70)
    
    # Get all J2C authentication aliases
    log("\nRetrieving all J2C authentication aliases...")
    aliases = get_all_j2c_aliases()
    
    if not aliases:
        log("No J2C authentication aliases found. Exiting.")
        return
    
    # Process each alias
    log("\nSearching for username '%s' in aliases..." % username)
    updated_count = 0
    updated_alias_names = []
    
    for alias in aliases:
        if alias:  # Skip empty entries
            alias_name = AdminConfig.showAttribute(alias, 'alias')
            current_user = AdminConfig.showAttribute(alias, 'userId')
            
            log("\nChecking alias: %s (user: %s)" % (alias_name, current_user))
            
            if update_j2c_password(alias, username, new_password):
                updated_count = updated_count + 1
                updated_alias_names.append(alias_name)
    
    # Summary
    log("\n" + "=" * 70)
    log("Update Summary:")
    log("  Total aliases checked: %d" % len(aliases))
    log("  Aliases updated: %d" % updated_count)
    if updated_alias_names:
        log("  Updated aliases: %s" % ", ".join(updated_alias_names))
    log("=" * 70)
    
    if updated_count > 0:
        log("\nSaving configuration changes...")
        try:
            AdminConfig.save()
            log("Configuration saved successfully!")
            
            # Synchronize nodes
            sync_success = sync_all_nodes()
            
            if sync_success:
                log("\nAll nodes synchronized successfully")
            else:
                log("\nWARNING: Some nodes failed to synchronize")
                log("Please check the logs above and manually sync if needed")
            
            # Validate password changes by testing datasource connections
            validation_results = validate_updated_aliases(updated_alias_names)
            
            # Print detailed summary
            print_detailed_summary(updated_alias_names, validation_results)
            
            log("\n" + "=" * 70)
            log("IMPORTANT: Next Steps")
            log("=" * 70)
            log("  1. Review the detailed summary above")
            log("  2. If servers are not running, start them and test manually")
            log("  3. No server restart required for J2C alias changes")
            log("  4. Monitor application logs for authentication issues")
            log("  5. Test application functionality that uses these aliases")
            log("=" * 70)
            
        except Exception, e:
            log("ERROR: Failed to save configuration!")
            log("Error details: %s" % str(e))
            log("Changes have NOT been persisted.")
            raise
    else:
        log("\nNo aliases found with username '%s'. No changes made." % username)
    
    log("\n" + "=" * 70)
    log("Script completed")
    log("=" * 70)

# Execute main function
if __name__ == '__main__' or __name__ == 'main':
    main()

