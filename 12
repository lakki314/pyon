2) Updated role YAML: roles/websphere_jvm_restart/tasks/build_one_host.yml

This is the critical change for “inventory has only localhost”.

✅ Adds hosts into:

umbrella group: wsjvm_restart_targets
env group: {{ role_group_prefix }}_{{ env_name }}

✅ Adds connection vars:

ansible_host
ansible_connection: ssh
---
- name: Initialize restart_requests
  set_fact:
    restart_requests: []

- name: Convert profiles map to list
  set_fact:
    profile_specs: "{{ host_spec.value | dict2items }}"

- name: Append profile/jvm pairs
  include_tasks: append_profile_jvms.yml
  loop: "{{ profile_specs }}"
  loop_control:
    loop_var: profile_spec
    label: "{{ env_name }} -> {{ host_spec.key }} -> {{ profile_spec.key }}"

- name: Add host to dynamic groups with connection vars
  add_host:
    name: "{{ host_spec.key }}"
    groups:
      - "wsjvm_restart_targets"                 # umbrella group for execute play
      - "{{ role_group_prefix }}_{{ env_name }}" # env group (dev/prod/etc)
    ansible_host: "{{ host_spec.key }}"          # resolves via DNS / hosts file
    ansible_connection: "ssh"
    # ansible_port: 22                          # optional if non-standard
    ritm_number: "{{ ritm_number }}"
    env_name: "{{ env_name }}"
    restart_requests: "{{ restart_requests }}"
