- name: Classify each JVM (AppServer vs nodeagent vs dmgr)
  set_fact:
    jvms_started_pre: "{{ jvms_started_pre + ([one_jvm] if started_hit else []) }}"
    jvms_stopped_pre: "{{ jvms_stopped_pre + ([one_jvm] if stopped_hit else []) }}"
  vars:
    started_hit: >-
      {{
        (
          (one_jvm == 'nodeagent' and (server_status_pre.stdout | default('') | regex_search('ADMU0508I: The Node Agent \"nodeagent\" is STARTED')) is not none)
          or
          (one_jvm == 'dmgr' and (server_status_pre.stdout | default('') | regex_search('ADMU0508I: The Deployment Manager \"dmgr\" is STARTED')) is not none)
          or
          (one_jvm not in ['dmgr','nodeagent'] and (server_status_pre.stdout | default('') | regex_search('ADMU0508I: The Application Server \"' ~ (one_jvm | regex_escape) ~ '\" is STARTED')) is not none)
