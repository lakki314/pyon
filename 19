# Expects from restart_profile.yml context:
# - result_jvm, profile_name
# - server_status_post (stdout / stdout_lines)
# - jvms_started_pre
# - detected_cell_name
# - profile_dir
# - jvm_results, env_name

# ---- PS after (no ternary) ----
- name: PS after for DMGR
  shell: "ps -ef | grep dmgr | grep {{ profile_name | quote }} | grep -v grep"
  register: _ps_after
  changed_when: false
  failed_when: false
  when: result_jvm == 'dmgr'

- name: PS after for NODEAGENT
  shell: "ps -ef | grep nodeagent | grep {{ profile_name | quote }} | grep -v grep"
  register: _ps_after
  changed_when: false
  failed_when: false
  when: result_jvm == 'nodeagent'

- name: PS after for AppServer
  shell: "ps -ef | grep java | grep {{ result_jvm | quote }} | grep -v grep"
  register: _ps_after
  changed_when: false
  failed_when: false
  when: result_jvm not in ['dmgr','nodeagent']

# ---- Normalize post serverStatus lines (for exact membership checks) ----
- name: Normalize serverStatus post lines
  set_fact:
    _post_lines_norm: >-
      {{
        (server_status_post.stdout_lines | default([]))
        | map('regex_replace', '\r', '')
        | map('regex_replace', '[ \t]+', ' ')
        | map('trim')
        | list
      }}
  changed_when: false

# ---- Build expected STARTED line for this JVM ----
- name: Build expected STARTED line for this JVM
  set_fact:
    _expected_started_line: >-
      {{
        (
          'ADMU0508I: The Node Agent "nodeagent" is STARTED'
          if result_jvm == 'nodeagent'
          else
          (
            'ADMU0508I: The Deployment Manager "dmgr" is STARTED'
            if result_jvm == 'dmgr'
            else
            ('ADMU0508I: The Application Server "' ~ (result_jvm | trim) ~ '" is STARTED')
          )
        )
      }}
  changed_when: false

# ---- Extract pid/cell and started_ok ----
- name: Extract pid/cell and started_ok
  set_fact:
    ps_after_lines: "{{ _ps_after.stdout_lines | default([]) }}"
    new_pid: "{{ (ps_after_lines | length > 0) | ternary((ps_after_lines[0].split()[1]), 'not found via ps') }}"
    cell_name: "{{ (ps_after_lines | length > 0) | ternary((ps_after_lines[0].split()[-3]), (detected_cell_name | default('unknown'))) }}"
    started_ok: "{{ _expected_started_line in _post_lines_norm }}"
  changed_when: false

# ---- Append result ----
- name: Append per-JVM result
  set_fact:
    jvm_results: >-
      {{
        jvm_results + [
          {
            'env_name': (env_name | default('na')),
            'env_host_profile_jvm': ((env_name | default('na')) ~ ':' ~ inventory_hostname ~ ':' ~ profile_name ~ ':' ~ result_jvm),
            'status': ( 'success' if started_ok else 'failed' ),
            'profile_dir': (profile_dir | default('unknown')),
            'cell_name': (cell_name | default('unknown')),
            'new_pid': (new_pid | default('')),
            'action': ( 'restart' if (result_jvm in jvms_started_pre) else 'start' ),
            'reason': ( '' if started_ok else ('Not STARTED after operations (missing: ' ~ _expected_started_line ~ ')') )
          }
        ]
      }}
