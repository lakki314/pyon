tasks/restart_started_jvm.yml (UPDATED)

✅ 3 separate tasks for PID capture
✅ 3 separate tasks for stop
✅ 3 separate tasks for start
✅ stop/start use become_user: jvm_owner_for_restart

---
- name: Initialize kill lookup vars
  set_fact:
    pid_to_kill: ""
    _pid_lines: []

- name: Capture PID for DMGR
  shell: "ps -ef | grep dmgr | grep {{ profile_name_for_restart | quote }} | grep -v grep"
  register: _ps_kill
  changed_when: false
  failed_when: false
  when: started_jvm == 'dmgr'

- name: Capture PID for NODEAGENT
  shell: "ps -ef | grep nodeagent | grep {{ profile_name_for_restart | quote }} | grep -v grep"
  register: _ps_kill
  changed_when: false
  failed_when: false
  when: started_jvm == 'nodeagent'

- name: Capture PID for AppServer
  shell: "ps -ef | grep java | grep {{ started_jvm | quote }} | grep -v grep"
  register: _ps_kill
  changed_when: false
  failed_when: false
  when: started_jvm not in ['dmgr','nodeagent']

- name: Extract pid_to_kill (first line)
  set_fact:
    _pid_lines: "{{ _ps_kill.stdout_lines | default([]) }}"
    pid_to_kill: "{{ (_pid_lines | length > 0) | ternary((_pid_lines[0].split()[1]), '') }}"

- name: Ensure PID is known
  assert:
    that:
      - pid_to_kill | length > 0
    fail_msg: "Cannot determine PID for {{ started_jvm }} in profile {{ profile_name_for_restart }}."

- name: Stop NODEAGENT (async)
  shell: "{{ profile_bin_for_restart }}/stopNode.sh"
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  async: "{{ stop_timeout_seconds }}"
  poll: 0
  changed_when: true
  when: started_jvm == 'nodeagent'

- name: Stop DMGR (async)
  shell: "{{ profile_bin_for_restart }}/stopManager.sh"
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  async: "{{ stop_timeout_seconds }}"
  poll: 0
  changed_when: true
  when: started_jvm == 'dmgr'

- name: Stop AppServer (async)
  shell: "{{ profile_bin_for_restart }}/stopServer.sh {{ started_jvm }}"
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  async: "{{ stop_timeout_seconds }}"
  poll: 0
  changed_when: true
  when: started_jvm not in ['dmgr','nodeagent']

- name: Wait up to timeout for PID to disappear (ps polling)
  block:
    - name: Poll ps until PID disappears
      shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
      register: pid_poll
      become: true
      become_user: "{{ jvm_owner_for_restart }}"
      changed_when: false
      failed_when: false
      retries: "{{ (stop_timeout_seconds // stop_check_delay) | int }}"
      delay: "{{ stop_check_delay }}"
      until: (pid_poll.stdout | default('') | trim) == ""
  rescue:
    - name: Kill -9 PID if still present
      shell: "kill -9 {{ pid_to_kill }}"
      become: true
      become_user: "{{ jvm_owner_for_restart }}"
      changed_when: true
      failed_when: false

    - name: Poll until PID disappears after kill -9
      shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
      register: pid_poll_after_kill
      become: true
      become_user: "{{ jvm_owner_for_restart }}"
      changed_when: false
      failed_when: false
      retries: 60
      delay: 5
      until: (pid_poll_after_kill.stdout | default('') | trim) == ""

- name: Final verify PID is gone before start
  shell: "ps -ef | awk '$2=={{ pid_to_kill }} {print}'"
  register: pid_final_check
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  changed_when: false
  failed_when: false

- name: Assert PID is gone
  assert:
    that:
      - (pid_final_check.stdout | default('') | trim) == ""
    fail_msg: "PID {{ pid_to_kill }} still exists; will not start {{ started_jvm }}."

- name: Start NODEAGENT
  shell: "{{ profile_bin_for_restart }}/startNode.sh"
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  changed_when: true
  when: started_jvm == 'nodeagent'

- name: Start DMGR
  shell: "{{ profile_bin_for_restart }}/startManager.sh"
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  changed_when: true
  when: started_jvm == 'dmgr'

- name: Start AppServer
  shell: "{{ profile_bin_for_restart }}/startServer.sh {{ started_jvm }}"
  become: true
  become_user: "{{ jvm_owner_for_restart }}"
  changed_when: true
  when: started_jvm not in ['dmgr','nodeagent']
