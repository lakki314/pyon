---
# Expects:
#   discover_jvm, profile_name, ps_discover_lines_accum

- name: PS discover DMGR (filtered by profile)
  shell: "ps -ef | grep dmgr | grep {{ profile_name | quote }} | grep -v grep"
  register: _ps_cmd
  changed_when: false
  failed_when: false
  when: discover_jvm == 'dmgr'

- name: PS discover NODEAGENT (filtered by profile)
  shell: "ps -ef | grep nodeagent | grep {{ profile_name | quote }} | grep -v grep"
  register: _ps_cmd
  changed_when: false
  failed_when: false
  when: discover_jvm == 'nodeagent'

- name: PS discover AppServer (java + jvm name)
  shell: "ps -ef | grep java | grep {{ discover_jvm | quote }} | grep -v grep"
  register: _ps_cmd
  changed_when: false
  failed_when: false
  when: discover_jvm not in ['dmgr','nodeagent']

