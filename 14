1) Updated banner_set_host.yml (NO getent, only if .profile exists)

File: roles/websphere_jvm_restart/tasks/banner_set_host.yml

---
# Inputs:
#  - banner_owner
#  - banner_summary
#
# Behavior:
#  - Only set banner if /home/<owner>/.profile exists
#  - Writes status file in /home/<owner>/

- name: Check if banner owner .profile exists
  stat:
    path: "/home/{{ banner_owner }}/{{ restart_banner_profile_filename }}"
  register: banner_profile_stat

- name: Debug - banner profile existence
  when: wsjvm_debug | bool
  debug:
    msg:
      banner_owner: "{{ banner_owner }}"
      profile_path: "/home/{{ banner_owner }}/{{ restart_banner_profile_filename }}"
      exists: "{{ banner_profile_stat.stat.exists | default(false) }}"

- name: Ensure .profile prints banner when status file exists
  when: banner_profile_stat.stat.exists | default(false)
  blockinfile:
    path: "/home/{{ banner_owner }}/{{ restart_banner_profile_filename }}"
    create: false
    marker: "# {mark} {{ restart_banner_block_id }}"
    block: |
      if [ -f "$HOME/{{ restart_banner_status_filename }}" ]; then
        echo "############################################################"
        cat "$HOME/{{ restart_banner_status_filename }}"
        echo "############################################################"
      fi
  become: true
  become_user: "{{ banner_owner }}"

- name: Write banner status file (only if .profile exists)
  when: banner_profile_stat.stat.exists | default(false)
  copy:
    dest: "/home/{{ banner_owner }}/{{ restart_banner_status_filename }}"
    mode: "0644"
    content: "{{ banner_summary }}\n"
  become: true
  become_user: "{{ banner_owner }}"

- name: Track owners touched (only if banner was applied)
  when: banner_profile_stat.stat.exists | default(false)
  set_fact:
    owners_touched: "{{ owners_touched | union([banner_owner]) }}"
