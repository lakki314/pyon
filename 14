NEW: roles/websphere_jvm_restart/tasks/banner_cleanup_one_owner.yml

This file performs cleanup for exactly one banner_owner.

---
# Expects: banner_owner

- name: Check if banner owner .profile exists
  stat:
    path: "/home/{{ banner_owner }}/{{ restart_banner_profile_filename }}"
  register: cleanup_profile_stat

- name: Remove status file (best effort)
  file:
    path: "/home/{{ banner_owner }}/{{ restart_banner_status_filename }}"
    state: absent
  become: true
  failed_when: false

- name: Remove managed .profile block (only if .profile exists)
  when: cleanup_profile_stat.stat.exists | default(false)
  blockinfile:
    path: "/home/{{ banner_owner }}/{{ restart_banner_profile_filename }}"
    marker: "# {mark} {{ restart_banner_block_id }}"
    state: absent
  become: true
UPDATED: roles/websphere_jvm_restart/tasks/banner_cleanup.yml

No block loop anymore — it loops the include.

---
- name: Cleanup banner artifacts for all touched owners (include_tasks loop)
  include_tasks: banner_cleanup_one_owner.yml
  loop: "{{ owners_touched | default([]) }}"
  loop_control:
    loop_var: banner_owner
    label: "cleanup banner for {{ banner_owner }}"
